---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRODUCTS } from '../lib/products.js';
import { verifyToken } from '../lib/token.js';

const tokenParam = Astro.url.searchParams.get('token') ?? '';
const secret = import.meta.env.DOWNLOAD_SECRET ?? '';

const payload = tokenParam ? verifyToken(secret, tokenParam) : null;
const product = payload ? PRODUCTS[payload.product] : null;

const fileIcons: Record<string, string> = {
  docx: 'ti-file-word',
  xlsx: 'ti-file-spreadsheet',
};
---

<BaseLayout
  title="Bedankt voor uw bestelling — MKBTechGids"
  description="Download uw NIS2 Compliance Toolkit bestanden."
>
  <main class="ty-main">
    <div class="ty-card">

      {product ? (
        <>
          <div class="ty-icon ty-icon--ok">
            <i class="ti ti-circle-check"></i>
          </div>
          <h1 class="ty-title">Bedankt voor uw bestelling!</h1>
          <p class="ty-sub">
            Uw <strong>{product.name}</strong> is gereed. Download alle bestanden in één klik als ZIP-archief.
            De links zijn 7 dagen geldig — sla de bestanden direct op.
          </p>

          <a
            href={`/downloads/${product.zipFile}`}
            download={product.zipFile}
            class="ty-zip-btn"
          >
            <span class="ty-zip-icon"><i class="ti ti-file-zip"></i></span>
            <span class="ty-zip-text">
              <strong>Download complete toolkit (ZIP)</strong>
              <small>{product.files.length} bestanden · één archief</small>
            </span>
            <span class="ty-zip-dl"><i class="ti ti-download"></i></span>
          </a>

          <details class="ty-files-details">
            <summary class="ty-files-summary">
              <i class="ti ti-list"></i> Bestanden afzonderlijk downloaden ({product.files.length})
            </summary>
            <div class="ty-files">
              {product.files.map((filename) => {
                const ext = filename.split('.').pop()?.toLowerCase() ?? 'docx';
                const icon = fileIcons[ext] ?? 'ti-file';
                const label = filename.replace(/^NIS2-/, '').replace(/\.(docx|xlsx|pdf|pptx)$/, '').replace(/-/g, ' ').replace(/_/g, ' ');
                return (
                  <a
                    href={`/downloads/${filename}`}
                    download={filename}
                    class="ty-file-row"
                  >
                    <span class="ty-file-icon"><i class={`ti ${icon}`}></i></span>
                    <span class="ty-file-name">{label}</span>
                    <span class="ty-file-ext">.{ext}</span>
                    <span class="ty-file-dl"><i class="ti ti-download"></i></span>
                  </a>
                );
              })}
            </div>
          </details>

          <p class="ty-email-note">
            Een bevestigingsmail met deze downloadlink en uw <strong>btw-factuur (PDF)</strong> is verstuurd naar het door u opgegeven e-mailadres.
            Niet ontvangen? Controleer uw spammap of mail naar
            <a href="mailto:info@mkbtechgids.nl">info@mkbtechgids.nl</a>.
          </p>

          <a href="/nis2-toolbox" class="ty-btn">Terug naar de toolkit pagina</a>
        </>
      ) : (
        <>
          <div class="ty-icon ty-icon--err">
            <i class="ti ti-alert-circle"></i>
          </div>
          <h1 class="ty-title">Downloadlink verlopen of ongeldig</h1>
          <p class="ty-sub">
            Deze link is niet meer geldig (links verlopen na 7 dagen). Controleer uw e-mail voor de originele link,
            of neem contact op via <a href="mailto:info@mkbtechgids.nl">info@mkbtechgids.nl</a> met uw bestelnummer.
          </p>
          <a href="/nis2-toolbox" class="ty-btn">Naar de toolkit pagina</a>
        </>
      )}

    </div>
  </main>
</BaseLayout>

<style>
  .ty-main {
    min-height: 70vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 60px 24px 80px;
    background: var(--g1, #f0fdf4);
  }

  .ty-card {
    background: var(--white, #fff);
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 48px 44px;
    max-width: 640px;
    width: 100%;
    box-shadow: 0 4px 32px rgba(15, 33, 71, 0.07);
  }

  .ty-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
    margin: 0 0 24px;
  }

  .ty-icon--ok {
    background: #f0fdf4;
    color: var(--green, #15803d);
  }

  .ty-icon--err {
    background: #fef2f2;
    color: #dc2626;
  }

  .ty-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--navy-dark, #0f2147);
    margin: 0 0 12px;
  }

  .ty-sub {
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.7;
    margin: 0 0 28px;
  }

  .ty-sub a,
  .ty-email-note a {
    color: var(--green, #15803d);
    text-decoration: underline;
  }

  .ty-zip-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    background: var(--green, #15803d);
    border-radius: 10px;
    text-decoration: none;
    color: #fff;
    margin-bottom: 20px;
    transition: opacity 0.15s;
  }

  .ty-zip-btn:hover {
    opacity: 0.9;
  }

  .ty-zip-icon {
    font-size: 28px;
    flex-shrink: 0;
  }

  .ty-zip-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ty-zip-text strong {
    font-size: 1rem;
    font-weight: 700;
  }

  .ty-zip-text small {
    font-size: 0.8rem;
    opacity: 0.85;
  }

  .ty-zip-dl {
    font-size: 22px;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .ty-files-details {
    margin-bottom: 28px;
  }

  .ty-files-summary {
    cursor: pointer;
    font-size: 0.875rem;
    color: #64748b;
    padding: 8px 4px;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
    user-select: none;
  }

  .ty-files-summary::-webkit-details-marker { display: none; }

  .ty-files-summary:hover {
    color: var(--navy-dark, #0f2147);
  }

  .ty-files {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
  }

  .ty-file-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    text-decoration: none;
    color: var(--navy-dark, #0f2147);
    font-size: 0.9rem;
    transition: background 0.14s, border-color 0.14s;
  }

  .ty-file-row:hover {
    background: #f0fdf4;
    border-color: var(--green, #15803d);
  }

  .ty-file-icon {
    font-size: 20px;
    color: #0369a1;
    flex-shrink: 0;
  }

  .ty-file-name {
    flex: 1;
    font-weight: 500;
  }

  .ty-file-ext {
    font-size: 0.75rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ty-file-dl {
    font-size: 18px;
    color: var(--green, #15803d);
    flex-shrink: 0;
  }

  .ty-email-note {
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.6;
    margin: 0 0 28px;
    padding: 14px 16px;
    background: #f8fafc;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  .ty-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background: var(--navy-dark, #0f2147);
    color: #fff;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .ty-btn:hover {
    opacity: 0.88;
  }

  @media (max-width: 600px) {
    .ty-card {
      padding: 32px 24px;
    }
  }
</style>
