    .task-check { width: 20px; height: 20px; border: 2px solid var(--bg-gray); border-radius: 4px; flex-shrink: 0; margin-top: 3px; }
    .task-text h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 4px; font-size: 14px; }
