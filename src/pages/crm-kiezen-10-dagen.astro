    .cost-table td { padding: 14px 16px; border-bottom: 1px solid var(--bg-gray); font-size: 14px; }
    .cost-table tr:last-child td { border-bottom: none; }
    .cost-table tr:nth-child(even) td { background: var(--bg-light); }
    .cost-total { font-weight: 700; color: var(--navy-dark); }

    .roi-box { background: var(--navy-dark); color: white; border-radius: 8px; padding: 32px; margin: 32px 0; }
    .roi-box h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--text-dark); margin-bottom: 20px; }
    .roi-stat { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 14px; }
    .roi-stat:last-child { border-bottom: none; }
    .roi-label { color: var(--text-light); }
