    .cta-section { background: var(--green); color: white; padding: 48px 36px; border-radius: 8px; margin: 56px 0; text-align: center; }
    .cta-section h3 { font-family: 'Playfair Display', serif; font-size: 24px; margin-bottom: 12px; }
    .cta-section p { color: white; margin-bottom: 28px; font-size: 15px; line-height: 1.7; }
    .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .cta-btn-primary { display: inline-block; background: white; color: var(--green); font-weight: 700; padding: 14px 32px; border-radius: 6px; transition: all 0.14s; font-size: 15px; }
    .cta-btn-primary:hover { background: var(--green-bg); }
    .cta-btn-secondary { display: inline-block; background: transparent; color: white; font-weight: 600; padding: 14px 32px; border-radius: 6px; border: 2px solid rgba(255,255,255,0.6); transition: all 0.14s; font-size: 15px; }
    .cta-btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.1); }
    .related-box { background: var(--bg-light); border: 2px solid var(--bg-gray); border-radius: 8px; padding: 28px; margin: 32px 0; }
    .related-box h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 16px; font-size: 15px; }
    .related-link { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--bg-gray); color: var(--text-body); font-size: 14px; transition: color 0.14s; }
    .related-link:last-child { border-bottom: none; }
    .related-link:hover { color: var(--green); }
    .related-link::before { content: '→'; color: var(--green); font-weight: 700; }
    .sources-section { border-top: 1px solid var(--bg-gray); padding-top: 28px; margin-top: 48px; }
    .sources-section h4 { font-size: 13px; font-weight: 700; color: var(--navy-dark); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .sources-section p { font-size: 12px; color: var(--text-body); line-height: 1.7; }
    .sources-section a { color: var(--navy-dark); text-decoration: underline; font-weight: 500; }
    .sources-section a:hover { color: var(--green); }
    .footer { background: var(--navy-dark); color: var(--text-light); padding: 48px 28px 24px; }
    .footer-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
