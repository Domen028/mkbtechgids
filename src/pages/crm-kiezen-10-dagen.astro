    .phase-body { background: white; border: 2px solid var(--bg-gray); border-top: none; border-radius: 0 0 6px 6px; padding: 0; margin-bottom: 20px; }
    .phase-task { display: flex; gap: 14px; align-items: flex-start; padding: 16px 24px; border-bottom: 1px solid var(--bg-gray); }
