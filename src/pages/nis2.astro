---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="NIS2 Implementatie"
  description="NIS2 implementatiegidsen — twee praktische artikelen voor Nederlandse MKB's."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <h1>NIS2 Implementatie — De volledige gids</h1>
      <p>Twee praktische artikelen om je bedrijf NIS2-compliant te maken. Van begrip tot concrete implementatie.</p>
    </div>
  </section>

  <section class="articles-content">
    <div class="articles-inner">
      <div class="articles-grid">
        <article class="article-item">
          <div class="article-category">Compliance · Begrip</div>
          <h2>NIS2 Compliance voor Nederlands MKB</h2>
          <p>Wat NIS2 betekent, of het voor jou van toepassing is, welke risico's je loopt, en waarom dit nu uitstel niet meer toelaat. Een helder overzicht van regelgeving, scope en bestuurdersaansprakelijkheid.</p>
          <div class="article-meta">
            <span>Juni 2026</span>
            <div class="article-meta-dot"></div>
            <span>8 minuten</span>
          </div>
          <a href="/nis2-compliance" class="article-cta">Lees het artikel</a>
        </article>

        <article class="article-item">
          <div class="article-category">Implementatie · Praktisch</div>
          <h2>Een praktische aanpak voor NIS2 implementatie</h2>
          <p>Stap-voor-stap plan met concrete gereedschappen, tool-aanbevelingen en een 12-maands roadmap. Van asset inventory tot continuous monitoring — alles wat je nodig hebt om NIS2-compliant te worden.</p>
          <div class="article-meta">
            <span>Juni 2026</span>
            <div class="article-meta-dot"></div>
            <span>8 minuten</span>
          </div>
          <a href="/nis2-compliancy" class="article-cta">Lees het artikel</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ── Page hero ───────────────────────────────────────── */
.page-hero {
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy-light) 100%);
  padding: 80px 28px; position: relative; overflow: hidden;
}
.page-hero::before {
  content: ''; position: absolute; inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 32px 32px; pointer-events: none;
}
.page-hero-inner { position: relative; max-width: 760px; margin: 0 auto; }
.page-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(32px, 5vw, 48px); font-weight: 700;
  color: var(--text-dark); line-height: 1.15; margin-bottom: 20px;
}
.page-hero p { font-size: 16px; color: var(--text-light); line-height: 1.8; }

/* ── Articles ────────────────────────────────────────── */
.articles-content { padding: 60px 28px; background: var(--s1); }
.articles-inner { max-width: var(--max-width); margin: 0 auto; }
.articles-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 36px; margin-top: 40px;
}
.article-item {
  background: var(--white); border: 2px solid var(--bg-gray);
  border-radius: var(--radius-md); padding: 36px;
  transition: all 0.2s; display: flex; flex-direction: column;
}
.article-item:hover { box-shadow: var(--shadow-green); transform: translateY(-4px); border-color: var(--green); }
.article-category {
  display: inline-block; background: rgba(20,83,45,0.1); color: var(--green);
  padding: 6px 12px; border-radius: var(--radius-sm);
  font-size: 10px; font-weight: 600; text-transform: uppercase; margin-bottom: 16px; width: fit-content;
}
.article-item h2 {
  font-family: var(--font-display);
  font-size: 22px; font-weight: 700; color: var(--navy-dark); margin-bottom: 12px; line-height: 1.3;
}
.article-item p { font-size: 14px; color: var(--s4); line-height: 1.7; margin-bottom: 24px; flex-grow: 1; }
.article-meta {
  font-size: 12px; color: var(--text-light);
  display: flex; gap: 12px; align-items: center; margin-bottom: 20px;
}
.article-meta-dot { width: 3px; height: 3px; background: var(--bg-gray); border-radius: 50%; }
.article-cta {
  display: inline-flex; align-items: center;
  font-size: 14px; font-weight: 600; color: var(--green-light);
  text-decoration: none; transition: color 0.14s;
}
.article-cta:hover { color: var(--green); }
.article-cta::after { content: '→'; margin-left: 8px; }

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 768px) {
  .page-hero { padding: 48px 28px; }
  .page-hero h1 { font-size: 32px; }
  .articles-grid { grid-template-columns: 1fr; gap: 24px; }
  .articles-content { padding: 40px 28px; }
}
</style>
