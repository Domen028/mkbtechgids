---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Uitschrijven — MKBTechGids"
  description="Informatie over uitschrijven van de MKBTechGids nieuwsbrief."
>
  <main class="unsub-main">
    <div class="unsub-card">
      <div class="unsub-icon">
        <i class="ti ti-mail"></i>
      </div>
      <h1 class="unsub-title">Uitschrijven</h1>
      <p class="unsub-body">
        Om u uit te schrijven klikt u op de <strong>afmelden</strong>-link
        onderaan een van onze e-mails. Dat verwijdert uw adres direct en automatisch.
      </p>
      <p class="unsub-body unsub-body--muted">
        Kunt u de e-mail niet terugvinden? Stuur ons een bericht via
        <a href="mailto:info@mkbtechgids.nl">info@mkbtechgids.nl</a>
        en wij regelen het handmatig.
      </p>
      <a href="/" class="unsub-btn">Terug naar de homepage</a>
    </div>
  </main>
</BaseLayout>

<style>
  .unsub-main {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px;
  }

  .unsub-card {
    background: var(--white, #fff);
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 48px 40px;
    max-width: 480px;
    width: 100%;
    text-align: center;
    box-shadow: 0 4px 24px rgba(15, 33, 71, 0.06);
  }

  .unsub-icon {
    width: 56px;
    height: 56px;
    background: #f0fdf4;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
    font-size: 26px;
    color: var(--green, #15803d);
  }

  .unsub-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--navy-dark, #0f2147);
    margin: 0 0 16px;
  }

  .unsub-body {
    font-size: 0.95rem;
    color: #4b5563;
    line-height: 1.65;
    margin: 0 0 16px;
  }

  .unsub-body--muted {
    font-size: 0.875rem;
    color: #94a3b8;
    margin-bottom: 28px;
  }

  .unsub-body a {
    color: var(--green, #15803d);
    text-decoration: underline;
  }

  .unsub-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    border-radius: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--navy-dark, #0f2147);
    color: #fff;
    transition: opacity 0.15s;
  }

  .unsub-btn:hover {
    opacity: 0.9;
  }
</style>
