---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="CRM Software voor Nederlands MKB — Onafhankelijke vergelijking — MKBTechGids"
  description="Welk CRM schaalt mee met uw groei zonder de overhead? Onafhankelijke vergelijking van HubSpot, Salesforce, Pipedrive en meer voor het Nederlandse MKB."
  noindex
>

  <section class="topic-hero">
    <div class="container">
      <div class="topic-hero-inner">
        <span class="badge badge--slate">Binnenkort beschikbaar</span>
        <h1>CRM Software</h1>
        <p class="topic-hero-sub">Welk CRM schaalt mee met uw groei zonder de overhead van een enterprise-platform? Onafhankelijke vergelijkingen op functionaliteit, kosten en implementatiegemak — specifiek voor het Nederlandse MKB.</p>
        <div class="topic-coming-meta">
          <span><i class="ti ti-calendar"></i> Verwacht Q4 2026</span>
          <span><i class="ti ti-files"></i> 3 vergelijkingen in voorbereiding</span>
        </div>
      </div>
    </div>
  </section>

  <section class="topic-preview section">
    <div class="container">
      <h2 class="topic-preview-title">Wat u kunt verwachten</h2>
      <div class="topic-preview-grid">
        <div class="topic-preview-card">
          <div class="topic-preview-num">01</div>
          <h3>HubSpot vs. Salesforce vs. Pipedrive — voor MKB</h3>
          <p>Een eerlijke vergelijking op implementatietijd, totale eigendomskosten, integratiemogelijkheden en schaalbaarheid. Met duidelijke aanbeveling per bedrijfsgrootte en sector.</p>
          <span class="badge badge--slate">In voorbereiding</span>
        </div>
        <div class="topic-preview-card">
          <div class="topic-preview-num">02</div>
          <h3>Van spreadsheet naar CRM — hoe doet u dat goed?</h3>
          <p>Migratiestrategie, data-opschoning en change management. Waarom de meeste CRM-implementaties mislukken en hoe u dat voorkomt.</p>
          <span class="badge badge--slate">In voorbereiding</span>
        </div>
        <div class="topic-preview-card">
          <div class="topic-preview-num">03</div>
          <h3>CRM + AI — de volgende stap voor uw salesteam</h3>
          <p>Hoe AI-functies in moderne CRM-systemen concreet tijd besparen: van lead scoring tot geautomatiseerde follow-ups en forecasting.</p>
          <span class="badge badge--slate">In voorbereiding</span>
        </div>
      </div>
    </div>
  </section>

  <section class="topic-notify section--green-tint section">
    <div class="container">
      <div class="topic-notify-inner">
        <i class="ti ti-bell topic-notify-icon"></i>
        <h2>Ontvang een melding zodra dit beschikbaar is</h2>
        <p>Meld u aan voor de MKBTechGids briefing en ontvang een melding zodra de CRM vergelijking live gaat.</p>
        <!-- BEEHIIV EMBED — vervang deze <form> met Beehiiv embed snippet wanneer account live is -->
        <form class="notify-form" id="notify-form-crm" novalidate>
          <input type="email" name="email" placeholder="uw@bedrijf.nl" required class="notify-input" />
          <button type="submit" class="btn btn--green">Houd mij op de hoogte →</button>
        </form>
        <p id="notify-thanks-crm" style="display:none;color:var(--green-light);font-size:0.9rem;margin-top:0.75rem">
          Ontvangen! U hoort van ons zodra de vergelijking live gaat.
        </p>
        <p class="notify-social-proof"><i class="ti ti-shield-check"></i> Geen spam. U kunt zich altijd uitschrijven.</p>
        <p class="notify-privacy"><i class="ti ti-shield-check"></i> Geen spam. Altijd afmelden mogelijk.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.topic-hero {
  background: linear-gradient(135deg, var(--s5) 0%, #0f2147 100%);
  padding: 80px 0 64px;
}
.topic-hero-inner { max-width: 680px; }
.topic-hero h1 {
  font-family: var(--font-display);
  font-size: 48px;
  color: var(--white);
  margin: 16px 0 20px;
  line-height: 1.15;
}
.topic-hero-sub {
  font-size: 18px;
  color: #94a3b8;
  line-height: 1.7;
  margin-bottom: 28px;
}
.topic-coming-meta {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
}
.topic-coming-meta span {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #64748b;
  font-family: var(--font-mono);
}
.topic-preview-title {
  font-family: var(--font-display);
  font-size: 28px;
  color: var(--s5);
  margin-bottom: 32px;
}
.topic-preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.topic-preview-card {
  background: var(--white);
  border: 1px solid var(--s2);
  border-radius: var(--radius-lg);
  padding: 28px;
}
.topic-preview-num {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--s3);
  margin-bottom: 12px;
  letter-spacing: 1px;
}
.topic-preview-card h3 {
  font-size: 16px;
  color: var(--s5);
  margin-bottom: 10px;
  line-height: 1.4;
}
.topic-preview-card p {
  font-size: 14px;
  color: var(--s4);
  line-height: 1.6;
  margin-bottom: 16px;
}
.topic-notify-inner {
  max-width: 560px;
  margin: 0 auto;
  text-align: center;
}
.topic-notify-icon {
  font-size: 32px;
  color: var(--g4);
  display: block;
  margin-bottom: 16px;
}
.topic-notify-inner h2 {
  font-family: var(--font-display);
  font-size: 28px;
  color: var(--s5);
  margin-bottom: 12px;
}
.topic-notify-inner p {
  color: var(--s4);
  margin-bottom: 28px;
  line-height: 1.7;
}
.notify-form {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}
.notify-input {
  flex: 1;
  padding: 11px 16px;
  border: 1px solid var(--s2);
  border-radius: var(--radius-md);
  font-size: 14px;
  font-family: var(--font-sans);
  background: var(--white);
}
.notify-input:focus { outline: none; border-color: var(--g4); }
.notify-social-proof {
  font-size: 12px;
  color: var(--g4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin: 0;
}
.notify-privacy {
  font-size: 12px;
  color: var(--s3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  margin: 0;
}
@media (max-width: 768px) {
  .topic-hero h1 { font-size: 32px; }
  .topic-preview-grid { grid-template-columns: 1fr; }
  .notify-form { flex-direction: column; }
}
</style>

<script>
// Placeholder — geen e-mailcapture tot Beehiiv embed live is.
const f = document.getElementById('notify-form-crm') as HTMLFormElement | null;
const t = document.getElementById('notify-thanks-crm');
f?.addEventListener('submit', (e) => { e.preventDefault(); if (f) f.style.display = 'none'; if (t) t.style.display = 'block'; });
</script>
