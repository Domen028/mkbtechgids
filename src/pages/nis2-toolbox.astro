---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRODUCTS, priceDisplay } from '../lib/products.js';
---

<BaseLayout
  title="NIS2 Compliance Toolkit — MKBTechGids"
  description="Praktische Word- en Excel-templates voor NIS2-compliance. Direct bruikbaar voor het Nederlandse MKB. Gratis Module 1 beschikbaar."
>

  <!-- Hero -->
  <section class="tk-hero">
    <div class="tk-hero-inner">
      <span class="tk-hero-badge">NIS2 Compliance Toolkit</span>
      <h1>Alles wat u nodig heeft om NIS2-compliant te worden</h1>
      <p>
        8 invulklare Word-modules + 7 Excel-registers + 5 instrumenten (o.a. Routekaart &amp; Gap-Analyse).
        Afgestemd op de Cyberbeveiligingswet — dekt alle 10 NIS2 Art. 21(2)-verplichtingen. Gevalideerd via een 8-perspectief review.
      </p>
      <div class="tk-hero-meta">
        <span><i class="ti ti-shield-check"></i> Alle NIS2 Art. 21(2) verplichtingen gedekt</span>
        <span><i class="ti ti-file-check"></i> Direct invulbaar, geen installatie</span>
        <span><i class="ti ti-award"></i> Big 4 kwaliteitsniveau</span>
        <span><i class="ti ti-certificate"></i> Klaar voor NIS2 SC10-audit</span>
      </div>
    </div>
  </section>

  <!-- Flash messages -->
  <div id="flash-wrapper"></div>

  <!-- Free module CTA bar -->
  <div class="tk-free-bar">
    <div class="tk-free-inner">
      <span><strong>Gratis:</strong> Module 1 (NIS2 Zelfevaluatie) — download zonder betaling</span>
      <a href="/api/dl?file=NIS2-Module1-Zelfevaluatie-v7.docx" class="tk-free-btn">
        <i class="ti ti-download"></i> Download gratis
      </a>
    </div>
  </div>

  <!-- Product bundles -->
  <section class="tk-section">
    <div class="tk-inner">
      <h2 class="tk-section-title">Kies uw pakket</h2>
      <p class="tk-section-sub">
        Eenmalige aankoop · Direct downloaden · 7 dagen downloadlink geldig
      </p>

      <div class="tk-grid">
        {Object.values(PRODUCTS).map((product) => (
          <div class={`tk-card${product.featured ? ' tk-card--featured' : ''}`}>
            <div class={`tk-tag${product.tagFeatured ? ' tk-tag--featured' : ''}`}>
              {product.tag}
            </div>

            <h3 class="tk-card-name">{product.name}</h3>
            <p class="tk-card-tagline">{product.tagline}</p>
            <p class="tk-card-desc">{product.description}</p>

            <ul class="tk-includes">
              {product.includes.map((item) => (
                <li><i class="ti ti-check"></i> {item}</li>
              ))}
            </ul>

            <div class="tk-price">
              {priceDisplay(product.priceEurCents)}
              <span class="tk-price-note">excl. btw · eenmalig</span>
            </div>

            <form method="POST" action="/api/checkout" class="tk-buy-form">
              <input type="hidden" name="product" value={product.id} />
              <input
                type="email"
                name="email"
                class="tk-email-input"
                placeholder="uw@bedrijf.nl"
                required
                autocomplete="email"
              />
              <button type="submit" class={`tk-buy-btn${product.featured ? ' tk-buy-btn--primary' : ''}`}>
                <i class="ti ti-credit-card"></i>
                Kopen — {priceDisplay(product.priceEurCents)}
              </button>
            </form>

            <p class="tk-mollie-note">
              <i class="ti ti-lock"></i> Veilig betalen via iDEAL · Mastercard · Visa
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SC10 audit callout -->
  <section class="tk-section">
    <div class="tk-inner">
      <div class="tk-sc10-callout">
        <div class="tk-sc10-icon"><i class="ti ti-certificate"></i></div>
        <div class="tk-sc10-body">
          <strong>Bereidt u voor op het NIS2 SC10-certificaat</strong>
          <p>
            Het NIS2 Supply Chain SC10-certificaat (voorheen QM10) toont uw klanten en opdrachtgevers aantoonbaar aan dat uw digitale beveiliging op orde is.
            De Complete Toolkit levert precies wat een erkende SC10-auditor verwacht: risicoregister, beveiligingsbeleid, verantwoordelijkheidsmatrix en volledig managementsysteemdocumentatie.
            <a href="https://www.stichting-kwaliteitsinnovatie.nl/nis2-supply-chain-certificering-voor-europa/" target="_blank" rel="noopener">Meer over het SC10-certificaat →</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's inside — full module list -->
  <section class="tk-section tk-section--alt">
    <div class="tk-inner">
      <h2 class="tk-section-title">Wat zit er in de Complete Toolkit?</h2>
      <p class="tk-section-sub">17 bestanden — alle NIS2 Art. 21(2) verplichtingen volledig gedekt</p>

      <div class="tk-contents-grid">
        <div class="tk-contents-col">
          <h4 class="tk-contents-head"><i class="ti ti-file-word"></i> 8 Word-modules</h4>
          <ul class="tk-contents-list">
            <li>M1 — NIS2 Zelfevaluatie</li>
            <li>M2 — Risicoanalyse</li>
            <li>M3 — Beveiligingsmaatregelen</li>
            <li>M4 — Leveranciersbeveiliging</li>
            <li>M5 — Bedrijfscontinuïteit & DRP</li>
            <li>M6 — Medewerkers & Bewustzijn</li>
            <li>M7 — Documentatie & Logging</li>
            <li>M8 — Jaarlijkse Review & Directieverklaring</li>
          </ul>
        </div>
        <div class="tk-contents-col">
          <h4 class="tk-contents-head"><i class="ti ti-file-spreadsheet"></i> 7 Excel-registers</h4>
          <ul class="tk-contents-list">
            <li>R1 — Risicoregister</li>
            <li>R2 — Activainventaris</li>
            <li>R3 — Leveranciersregister</li>
            <li>R4 — Incidentenlog (Art. 23 gereed)</li>
            <li>R5 — Compliance Dashboard (M1–M8)</li>
            <li>R6 — Trainingsregister</li>
            <li>R7 — Logregister</li>
          </ul>
        </div>
        <div class="tk-contents-col">
          <h4 class="tk-contents-head"><i class="ti ti-chart-bar"></i> 5 Instrumenten</h4>
          <ul class="tk-contents-list">
            <li>Beheersmaatregelkaart</li>
            <li>Dreigingscatalogus</li>
            <li>NIS2-Routekaart</li>
            <li>Gap-Analyse</li>
            <li>Bewustzijnsverklaring</li>
          </ul>
          <div class="tk-audit-badge">
            <i class="ti ti-shield-check"></i>
            <div>
              <strong>Gevalideerd</strong>
              <p>Alle 10 NIS2 Art. 21(2) verplichtingen gedekt. 8-perspectief validatie inclusief NIS2-expert, CISO, Big 4-consultant en CFO-perspectief.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison: consultant vs toolkit -->
  <section class="tk-section">
    <div class="tk-inner">
      <h2 class="tk-section-title">Onafhankelijk advies besparen</h2>
      <div class="tk-compare">
        <div class="tk-compare-col tk-compare-col--them">
          <div class="tk-compare-head">Consultant quickscan</div>
          <div class="tk-compare-price">€2.000 – €5.000</div>
          <ul>
            <li>Eenmalig adviesrapport</li>
            <li>Geen invulbare templates</li>
            <li>Geen dossier voor toezichthouder</li>
            <li>Afhankelijk van externe partij</li>
          </ul>
        </div>
        <div class="tk-compare-vs">vs.</div>
        <div class="tk-compare-col tk-compare-col--us">
          <div class="tk-compare-head">Complete Toolkit</div>
          <div class="tk-compare-price">€249</div>
          <ul>
            <li><i class="ti ti-check"></i> 20 direct invulbare bestanden</li>
            <li><i class="ti ti-check"></i> Volledig NIS2-dossier voor toezichthouder</li>
            <li><i class="ti ti-check"></i> Onafhankelijk — uw eigen bezit</li>
            <li><i class="ti ti-check"></i> Direct beschikbaar</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Conversion bridge to TechLeadNL -->
  <section class="tk-section">
    <div class="tk-inner">
      <div class="tk-bridge">
        <div class="tk-bridge-text">
          <h3>Heeft uw directieteam iemand nodig die dit overziet op strategisch niveau?</h3>
          <p>De toolkit geeft u de tools om NIS2-compliant te worden. TechLeadNL geeft u de technologieleider die dit strategisch aanstuurt — als permanent deeltijds lid van uw directieteam.</p>
        </div>
        <a href="https://www.techleadnl.nl" class="tk-bridge-btn" target="_blank" rel="noopener">
          Bekijk TechLeadNL →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="tk-section tk-section--alt">
    <div class="tk-inner">
      <h2 class="tk-section-title">Veelgestelde vragen</h2>
      <div class="tk-faq">
        <details class="tk-faq-item">
          <summary class="tk-faq-q">Helpt de toolkit bij het behalen van het NIS2 SC10-certificaat?</summary>
          <div class="tk-faq-a">
            Ja. Het NIS2 Supply Chain SC10-certificaat (voorheen QM10) vereist een aantoonbaar werkend managementsysteem met risicoregister, beveiligingsbeleid, verantwoordelijkheidsmatrix en documentatie van alle maatregelen. De <strong>Complete Toolkit</strong> levert al deze componenten kant-en-klaar. U vult de templates in op uw organisatie, en heeft direct het dossier dat een erkende SC10-auditor verwacht. Voor de formele audit heeft u een externe, gecertificeerde auditor nodig — de toolkit bereidt u voor, zodat u die audit met vertrouwen ingaat.
          </div>
        </details>

        <details class="tk-faq-item">
          <summary class="tk-faq-q">Welk pakket kies ik?</summary>
          <div class="tk-faq-a">
            Begin met de <strong>Complete Toolkit (€249)</strong> als u een volledig NIS2-dossier wilt voor de toezichthouder.
            De <strong>Core Bundle (€129)</strong> dekt het fundament (M1–M5 + risicoregister). <strong>Quick Start (€49)</strong> is voor wie snel wil starten met de basics.
          </div>
        </details>
        <details class="tk-faq-item">
          <summary class="tk-faq-q">Kan ik de templates aanpassen?</summary>
          <div class="tk-faq-a">
            Ja. Alle Word-bestanden zijn volledig bewerkbaar. De Excel-registers hebben beschermde formules maar invulbare cellen. U past alles aan naar uw organisatie.
          </div>
        </details>
        <details class="tk-faq-item">
          <summary class="tk-faq-q">Hoe lang duurt invullen?</summary>
          <div class="tk-faq-a">
            Elke module kost gemiddeld 2–4 uur. De volledige Complete Toolkit kost 24–30 uur totaal, afhankelijk van uw organisatie. Verdeeld over meerdere sessies is dit prima te behappen.
          </div>
        </details>
        <details class="tk-faq-item">
          <summary class="tk-faq-q">Hoe ontvang ik de bestanden?</summary>
          <div class="tk-faq-a">
            Direct na betaling wordt u doorgestuurd naar een beveiligde downloadpagina. U ontvangt ook een bevestigingsmail met de downloadlink (geldig 7 dagen). Sla de bestanden op zodra u ze heeft gedownload.
          </div>
        </details>
        <details class="tk-faq-item">
          <summary class="tk-faq-q">Geldt er btw?</summary>
          <div class="tk-faq-a">
            De getoonde prijzen zijn exclusief btw (21%). Bij afrekening wordt de btw opgeteld. Btw-nummer: NL004968309B61.
          </div>
        </details>
        <details class="tk-faq-item">
          <summary class="tk-faq-q">Wat als ik vragen heb bij het invullen?</summary>
          <div class="tk-faq-a">
            Elke module bevat een uitgewerkt invulvoorbeeld (§7) en instructies. Bij het <strong>Full Package (€349)</strong> is e-mailondersteuning inbegrepen. Voor losse vragen: <a href="mailto:info@mkbtechgids.nl">info@mkbtechgids.nl</a>.
          </div>
        </details>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Show flash message based on URL param
  const params = new URLSearchParams(window.location.search);
  const betaling = params.get('betaling');
  const wrapper = document.getElementById('flash-wrapper');

  if (betaling && wrapper) {
    const messages: Record<string, { type: string; text: string }> = {
      canceled:    { type: 'warn', text: 'Betaling geannuleerd. U kunt het opnieuw proberen.' },
      failed:      { type: 'err',  text: 'Betaling mislukt. Probeer een andere betaalmethode.' },
      expired:     { type: 'warn', text: 'Sessie verlopen. U kunt het opnieuw proberen.' },
      mislukt:     { type: 'err',  text: 'Er is iets misgegaan. Probeer het opnieuw of mail info@mkbtechgids.nl.' },
      verwerking:  { type: 'info', text: 'Uw betaling wordt verwerkt. U ontvangt een bevestigingsmail zodra dit gereed is.' },
      'config-fout': { type: 'err', text: 'Betaling tijdelijk niet beschikbaar. Mail info@mkbtechgids.nl.' },
    };

    const msg = messages[betaling];
    if (msg) {
      wrapper.innerHTML = `<div class="tk-flash tk-flash--${msg.type}" role="alert">${msg.text}</div>`;
    }
  }
</script>

<style>
  /* ── Hero ───────────────────────────────────────────────────── */
  .tk-hero {
    background: linear-gradient(135deg, var(--navy-dark, #0f2147) 0%, #1a3366 100%);
    padding: 72px 28px 60px;
    position: relative;
    overflow: hidden;
  }

  .tk-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .tk-hero-inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
  }

  .tk-hero-badge {
    display: inline-block;
    background: rgba(21, 128, 61, 0.3);
    color: #4ade80;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 20px;
    border: 1px solid rgba(74, 222, 128, 0.2);
  }

  .tk-hero h1 {
    font-size: clamp(26px, 4vw, 42px);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .tk-hero p {
    font-size: 17px;
    color: #94a3b8;
    line-height: 1.7;
    margin: 0 0 28px;
    max-width: 620px;
  }

  .tk-hero-meta {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .tk-hero-meta span {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    color: #cbd5e1;
  }

  .tk-hero-meta .ti {
    color: #4ade80;
    font-size: 16px;
  }

  /* ── Flash ─────────────────────────────────────────────────── */
  .tk-flash {
    max-width: 1100px;
    margin: 16px auto 0;
    padding: 14px 20px;
    border-radius: 8px;
    font-size: 0.9rem;
  }

  .tk-flash--warn { background: #fffbeb; border: 1px solid #fcd34d; color: #92400e; }
  .tk-flash--err  { background: #fef2f2; border: 1px solid #fca5a5; color: #dc2626; }
  .tk-flash--info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }

  /* ── Free bar ──────────────────────────────────────────────── */
  .tk-free-bar {
    background: var(--g1, #f0fdf4);
    border-bottom: 1px solid #bbf7d0;
    padding: 14px 28px;
  }

  .tk-free-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 14px;
    color: var(--navy-dark, #0f2147);
  }

  .tk-free-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    background: var(--green, #15803d);
    color: #fff;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.14s;
  }

  .tk-free-btn:hover { background: #14532d; }

  /* ── Sections ──────────────────────────────────────────────── */
  .tk-section { padding: 72px 28px; }
  .tk-section--alt { background: var(--g1, #f0fdf4); }

  .tk-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .tk-section-title {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 700;
    color: var(--navy-dark, #0f2147);
    margin: 0 0 8px;
  }

  .tk-section-sub {
    font-size: 15px;
    color: #64748b;
    margin: 0 0 44px;
  }

  /* ── Product grid ──────────────────────────────────────────── */
  .tk-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }

  .tk-card {
    background: #fff;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .tk-card:hover {
    box-shadow: 0 8px 32px rgba(15, 33, 71, 0.1);
    transform: translateY(-3px);
  }

  .tk-card--featured {
    border-color: var(--green, #15803d);
    background: #f0fdf4;
  }

  .tk-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    background: #f1f5f9;
    color: #475569;
    margin-bottom: 14px;
    width: fit-content;
  }

  .tk-tag--featured {
    background: var(--green, #15803d);
    color: #fff;
  }

  .tk-card-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--navy-dark, #0f2147);
    margin: 0 0 4px;
  }

  .tk-card-tagline {
    font-size: 0.85rem;
    color: var(--green, #15803d);
    font-weight: 600;
    margin: 0 0 14px;
  }

  .tk-card-desc {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.65;
    margin: 0 0 18px;
    flex-grow: 1;
  }

  .tk-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tk-includes li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.82rem;
    color: #374151;
    line-height: 1.5;
  }

  .tk-includes .ti {
    color: var(--green, #15803d);
    font-size: 14px;
    margin-top: 1px;
    flex-shrink: 0;
  }

  .tk-price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--navy-dark, #0f2147);
    margin-bottom: 16px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .tk-price-note {
    font-size: 0.75rem;
    font-weight: 400;
    color: #94a3b8;
  }

  /* ── Checkout form ──────────────────────────────────────────── */
  .tk-buy-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tk-email-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #d1d5db;
    border-radius: 7px;
    font-size: 0.9rem;
    color: #1f2937;
    background: #f9fafb;
    box-sizing: border-box;
    transition: border-color 0.14s;
  }

  .tk-email-input:focus {
    outline: none;
    border-color: var(--green, #15803d);
    background: #fff;
  }

  .tk-buy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--navy-dark, #0f2147);
    color: #fff;
    border: none;
    border-radius: 7px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.14s, opacity 0.14s;
    width: 100%;
    text-align: center;
  }

  .tk-buy-btn:hover { opacity: 0.88; }

  .tk-buy-btn--primary {
    background: var(--green, #15803d);
    font-size: 0.95rem;
    padding: 14px 20px;
  }

  .tk-buy-btn--primary:hover { background: #14532d; opacity: 1; }

  .tk-mollie-note {
    margin: 8px 0 0;
    font-size: 0.75rem;
    color: #94a3b8;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  /* ── Contents grid ──────────────────────────────────────────── */
  .tk-contents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 32px;
  }

  .tk-contents-head {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--navy-dark, #0f2147);
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tk-contents-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tk-contents-list li {
    font-size: 0.875rem;
    color: #374151;
    padding-left: 14px;
    position: relative;
  }

  .tk-contents-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--green, #15803d);
    font-weight: 700;
  }

  .tk-audit-badge {
    display: flex;
    gap: 12px;
    padding: 14px 16px;
    background: #fff;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    align-items: flex-start;
  }

  .tk-audit-badge > .ti {
    font-size: 20px;
    color: var(--green, #15803d);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tk-audit-badge strong {
    display: block;
    font-size: 0.85rem;
    color: var(--navy-dark, #0f2147);
    margin-bottom: 4px;
  }

  .tk-audit-badge p {
    font-size: 0.8rem;
    color: #64748b;
    line-height: 1.55;
