    p { margin-bottom: 18px; color: var(--text-body); line-height: 1.8; }
    strong { color: var(--navy-dark); font-weight: 600; }
    ul, ol { margin-left: 24px; margin-bottom: 18px; color: var(--text-body); }
    li { margin-bottom: 12px; line-height: 1.7; }

