    .gap-section h3 { font-weight: 700; color: var(--navy-dark); margin-bottom: 12px; font-size: 16px; margin-top: 0; }
    .gap-section p { font-size: 14px; margin-bottom: 8px; }

    .stats-box { background: var(--navy-dark); color: var(--text-dark); border-radius: 8px; padding: 40px 28px; margin: 32px 0; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 28px; text-align: center; }
    .stat-item { }
    .stat-num { font-family: 'Playfair Display', serif; font-size: 40px; font-weight: 700; color: var(--green-light); margin-bottom: 8px; }
    .stat-label { font-size: 13px; color: var(--text-light); line-height: 1.6; }
    .stats-credit { font-size: 12px; color: var(--text-light); text-align: center; margin-top: 24px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); }

    .steps-box { background: var(--green-bg); border: 2px solid var(--green); border-radius: 8px; padding: 32px; margin: 32px 0; }
    .steps-grid { display: flex; flex-direction: column; gap: 24px; }
    .step { display: flex; gap: 20px; }
    .step-number { background: var(--green); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
    .step-content h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 8px; font-size: 15px; }
    .step-content p { font-size: 14px; }

    .cta-section { background: var(--navy-dark); color: var(--text-dark); padding: 40px 28px; border-radius: 8px; margin: 56px 0; text-align: center; }
    .cta-section h3 { font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 12px; color: var(--text-dark); margin-top: 0; }
    .cta-section p { color: var(--text-light); margin-bottom: 20px; }
    .cta-btn { display: inline-block; background: var(--green); color: white; font-weight: 600; padding: 12px 28px; border-radius: 6px; text-decoration: none; transition: background 0.14s; }
    .cta-btn:hover { background: var(--green-light); }

    .resources-box { background: var(--green-bg); border: 2px solid var(--green); border-radius: 8px; padding: 24px; margin: 32px 0; }
    .resources-box h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 16px; }
    .resources-box a { display: block; color: var(--green); font-weight: 600; font-size: 14px; margin-bottom: 12px; transition: color 0.14s; }
    .resources-box a:hover { color: var(--green-light); }

    .footer-meta { border-top: 1px solid var(--bg-gray); padding-top: 24px; margin-top: 40px; font-size: 13px; color: var(--text-body); line-height: 1.7; }

    .footer { background: var(--navy-dark); color: var(--text-light); padding: 48px 28px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
    .footer-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
    .footer p { font-size: 13px; margin: 0; }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .nav-toggle { display: flex; margin-left: auto; }
