---
// src/pages/index.astro — MKBTechGids homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Topics from '../components/Topics.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout
  title="MKBTechGids — Technologiegids voor het Nederlandse MKB"
  description="Onafhankelijke analyses van tech-regulering, software en digitale strategie voor Nederlandse bestuurders, CFO's en investeerders. Geen jargon. Wel het eerlijke beeld."
>

  <!-- Hero + urgency strip -->
  <Hero />

  <!-- Methodology strip -->
  <section class="method-strip" aria-label="Onze aanpak">
    <div class="container method-inner">
      <div class="method-step">
        <span class="method-num" aria-hidden="true">01</span>
        <span class="method-title">Verkennen</span>
        <span class="method-desc">Onafhankelijk marktonderzoek zonder commerciële belangen.</span>
      </div>
      <span class="method-arrow" aria-hidden="true">→</span>
      <div class="method-step">
        <span class="method-num" aria-hidden="true">02</span>
        <span class="method-title">Beoordelen</span>
        <span class="method-desc">Gestructureerde analyse op TCO, risico en schaalbaarheid.</span>
      </div>
      <span class="method-arrow" aria-hidden="true">→</span>
      <div class="method-step">
        <span class="method-num" aria-hidden="true">03</span>
        <span class="method-title">Adviseren</span>
        <span class="method-desc">Helder advies — wat ú als bestuurder moet weten en doen.</span>
      </div>
    </div>
  </section>

  <!-- Topics grid -->
  <Topics />

  <!-- Newsletter -->
  <NewsletterSignup />

  <!-- TechLead NL crosslink -->
  <section class="crosslink" aria-labelledby="crosslink-heading">
    <div class="container crosslink-inner">
      <div class="crosslink-copy">
        <p class="crosslink-eyebrow">Fractional Technology Leadership</p>
        <h2 id="crosslink-heading" class="crosslink-title">
          Heeft uw organisatie meer nodig dan een gids?
        </h2>
        <p class="crosslink-text">
          MKBTechGids geeft u het overzicht. TechLead NL geeft u de leiding —
          als fractional CTO, CIO of Chief Architect, ingebed in uw organisatie,
          voor een fractie van de kosten van een fulltime hire.
        </p>
      </div>
      <a href="https://techleadnl.nl" class="crosslink-btn" rel="noopener" aria-label="Naar TechLead NL — fractional technology leadership">
        TechLead NL <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Methodology strip ───────────────────────────────────── */
.method-strip {
  background: var(--n4);
  border-top: 1px solid rgba(30,58,110,0.5);
  border-bottom: 1px solid rgba(30,58,110,0.4);
  padding: 28px 0;
}
.method-inner {
  display: flex;
  align-items: center;
  gap: 0;
  flex-wrap: wrap;
}
.method-step {
  display: flex;
  flex-direction: column;
  gap: 3px;
  flex: 1;
  min-width: 160px;
  padding: 0 24px;
}
.method-step:first-child { padding-left: 0; }
.method-num {
  font-size: 11px;
  font-weight: 700;
  color: var(--g4);
  letter-spacing: 0.06em;
}
.method-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--s2);
}
.method-desc {
  font-size: 12px;
  color: var(--s3);
  line-height: 1.5;
}
.method-arrow {
  font-size: 18px;
  color: rgba(148,163,184,0.3);
  flex-shrink: 0;
  margin: 0 4px;
}

/* ── TechLead NL crosslink ───────────────────────────────── */
.crosslink {
  background: var(--s1);
  border-top: 1px solid var(--s2);
  padding: 52px 0;
}
.crosslink-inner {
  display: flex;
  align-items: center;
  gap: 48px;
  flex-wrap: wrap;
}
.crosslink-copy { flex: 1; min-width: 280px; }
.crosslink-eyebrow {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: var(--g4);
  margin-bottom: 8px;
}
.crosslink-title {
  font-family: var(--font-display);
  font-size: clamp(20px, 2.5vw, 26px);
  font-weight: 700;
  color: var(--s5);
  letter-spacing: -0.02em;
  margin-bottom: 12px;
  line-height: 1.2;
}
.crosslink-text {
  font-size: 14.5px;
  color: var(--s4);
  line-height: 1.7;
  max-width: 480px;
}
.crosslink-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--n5);
  color: var(--g2);
  font-size: 14px;
  font-weight: 600;
  padding: 13px 26px;
  border-radius: var(--r-sm);
  white-space: nowrap;
  transition: background 0.15s, transform 0.15s;
  flex-shrink: 0;
}
.crosslink-btn:hover {
  background: var(--n4);
  transform: translateY(-1px);
}

@media (max-width: 640px) {
  .method-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .method-step { padding: 0; }
  .method-arrow { display: none; }
  .crosslink-inner { flex-direction: column; gap: 24px; }
}
</style>
