---
export const prerender = true;
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Onafhankelijke technologiegids voor het Nederlandse MKB" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <title>MKBTechGids — De technologieroute al verkend</title>
  <style>
    :root {
      --navy-dark: #0f2147;
      --navy-light: #1e3a6e;
      --green: #14532d;
      --green-light: #15803d;
      --green-bg: #f0fdf4;
      --text-dark: #f1f5f9;
      --text-light: #94a3b8;
      --bg-light: #f8fafc;
      --bg-gray: #e2e8f0;
      --text-body: #475569;
    }
    
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; background: var(--bg-light); color: var(--text-body); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    img, svg { display: block; max-width: 100%; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 28px; }

    .site-header { position: sticky; top: 0; z-index: 200; background: var(--bg-light); border-bottom: 1px solid var(--bg-gray); box-shadow: 0 1px 6px rgba(15, 33, 71, 0.07); }
    .header-inner { display: flex; align-items: center; gap: 36px; height: 68px; max-width: 1100px; margin: 0 auto; padding: 0 28px; }
    .nav-logo { flex-shrink: 0; display: flex; align-items: center; }
    .nav-logo img { height: 46px; width: auto; }
    .nav-links { display: flex; gap: 28px; flex: 1; margin: 0; padding: 0; }
    .nav-links a { font-size: 13.5px; font-weight: 500; color: var(--text-body); padding: 4px 0; border-bottom: 2px solid transparent; transition: color 0.14s; }
    .nav-links a:hover { color: var(--green); border-bottom-color: var(--green); }
    .nav-cta { font-size: 13px; font-weight: 600; color: white; background: var(--green); border-radius: 6px; padding: 8px 18px; text-decoration: none; transition: background 0.14s; border: none; cursor: pointer; }
    .nav-cta:hover { background: var(--green-light); }
    .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
    .nav-toggle span { display: block; width: 22px; height: 2px; background: var(--text-body); border-radius: 2px; }
    .mobile-menu { display: none; }
    .mobile-menu:not([hidden]) { display: flex; flex-direction: column; background: var(--bg-light); border-top: 1px solid var(--bg-gray); padding: 8px 28px 20px; }
    .mobile-menu a { font-size: 15px; font-weight: 500; color: var(--text-body); padding: 12px 0; border-bottom: 1px solid var(--bg-gray); }
    .mobile-menu a:hover { color: var(--green); }
    .mobile-menu a:last-child { border-bottom: none; }

    .hero { background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy-light) 100%); padding: 120px 28px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px; pointer-events: none; }
    .hero-inner { position: relative; max-width: 700px; margin: 0 auto; }
    .hero-badge { display: inline-block; border: 1px solid var(--green); border-radius: 6px; padding: 8px 16px; margin-bottom: 24px; font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--text-dark); }
    .hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(40px, 6vw, 56px); font-weight: 700; color: var(--text-dark); line-height: 1.1; margin-bottom: 20px; }
    .hero h1 em { font-style: normal; color: var(--green-light); }
    .hero p { font-size: 16px; color: var(--text-light); line-height: 1.8; margin-bottom: 32px; max-width: 600px; }
    .hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 60px; }
    .stat { border-left: 2px solid var(--green); padding-left: 20px; }
    .stat-num { font-size: 36px; font-weight: 700; color: var(--green-light); }
    .stat-label { font-size: 12px; color: var(--text-light); text-transform: uppercase; margin-top: 8px; }

    .signal { background: var(--navy-dark); border-top: 2px solid var(--green); padding: 16px 28px; }
    .signal-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; gap: 16px; }
    .signal-icon { width: 48px; height: 48px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 24px; }
    .signal-text { font-size: 14px; font-weight: 500; color: var(--text-dark); }

    .topics { padding: 80px 28px; background: var(--bg-light); }
    .topics-inner { max-width: 1100px; margin: 0 auto; }
    .topics h2 { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; margin-bottom: 12px; color: var(--navy-dark); }
    .topics-desc { font-size: 16px; color: var(--text-body); margin-bottom: 48px; max-width: 700px; }
    .topics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 28px; }
    .topic-card { background: white; border: 2px solid var(--bg-gray); border-radius: 8px; padding: 28px; transition: all 0.2s; }
    .topic-card.featured { background: var(--green-bg); border-color: var(--green); }
    .topic-card:hover { box-shadow: 0 8px 24px rgba(15, 33, 71, 0.1); transform: translateY(-2px); }
    .topic-tag { display: inline-block; background: rgba(20, 83, 45, 0.1); color: var(--green); padding: 4px 10px; border-radius: 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; margin-bottom: 12px; }
    .topic-card.featured .topic-tag { background: rgba(20, 83, 45, 0.2); }
    .topic-card h3 { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--navy-dark); margin-bottom: 12px; }
    .topic-card p { font-size: 14px; color: var(--text-body); line-height: 1.7; }
    .topic-status { display: inline-block; margin-top: 16px; font-size: 13px; font-weight: 600; color: var(--green); }
    .topic-status::before { content: '●'; margin-right: 6px; }

    .newsletter { background: var(--navy-dark); padding: 80px 28px; position: relative; overflow: hidden; }
    .nl-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
    .nl-copy h2 { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: var(--text-dark); margin-bottom: 16px; }
    .nl-copy p { font-size: 15px; color: var(--text-light); line-height: 1.8; margin-bottom: 20px; }
    .nl-promises { list-style: none; margin: 0; padding: 0; }
    .nl-promises li { font-size: 14px; color: var(--text-light); padding: 8px 0; padding-left: 24px; position: relative; }
    .nl-promises li::before { content: '✓'; position: absolute; left: 0; color: var(--green-light); font-weight: 700; }
    .nl-form { display: flex; flex-direction: column; gap: 16px; }
    .form-field { display: flex; flex-direction: column; gap: 10px; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); }
    .form-input, .form-select { background: rgba(255,255,255,0.95); border: 1px solid var(--bg-gray); border-radius: 6px; padding: 14px 14px; font-size: 15px; font-family: inherit; height: 48px; line-height: 1.2; }
    .form-input:focus, .form-select:focus { outline: none; border-color: var(--green); box-shadow: 0 0 0 2px rgba(20, 83, 45, 0.1); }
    .form-select { appearance: none; background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23475569' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e"); background-repeat: no-repeat; background-position: right 10px center; background-size: 20px; padding-right: 36px; }
    .nl-form button { background: var(--green); color: white; border: none; border-radius: 6px; padding: 14px 24px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.14s; height: 48px; line-height: 1.2; display: flex; align-items: center; justify-content: center; }
    .nl-form button:hover { background: var(--green-light); }
    .nl-msg { font-size: 13px; margin-top: 12px; min-height: 20px; }

    .footer { background: var(--navy-dark); color: var(--text-light); padding: 48px 28px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
    .footer-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
    .footer p { font-size: 13px; margin: 0; }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .nav-toggle { display: flex; margin-left: auto; }
      .hero { padding: 80px 28px; }
      .hero h1 { font-size: 32px; }
      .hero-stats { grid-template-columns: 1fr; gap: 24px; }
      .nl-inner { grid-template-columns: 1fr; gap: 40px; }
      .topics-grid { grid-template-columns: 1fr; }
      .signal-inner { flex-direction: column; text-align: center; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="nav-logo"><img src="/logo.svg" alt="MKBTechGids" width="48" height="51" /></a>
      <nav class="nav-links">
        <a href="/nis2">NIS2</a>
        <a href="/">AI Governance</a>
        <a href="/">AI Tools</a>
        <a href="/">CRM</a>
        <a href="/">Artikelen</a>
      </nav>
      <a href="/nis2" class="nav-cta">NIS2 gids →</a>
      <button class="nav-toggle" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
    <nav id="mobile-menu" class="mobile-menu" hidden>
      <a href="/nis2">NIS2</a>
      <a href="/">AI Governance</a>
      <a href="/">AI Tools</a>
      <a href="/">CRM</a>
      <a href="/">Artikelen</a>
      <a href="/nis2" class="mobile-cta">NIS2 gids lezen →</a>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-badge">● Onafhankelijk · Geen advertenties · Nederlands MKB</div>
        <h1>Technologie beslist mee.<br><em>Of u het ziet of niet.</em></h1>
        <p>Voor bestuurders, CFO's en investeerders die willen begrijpen wat technologiekeuzes werkelijk betekenen voor bedrijfswaarde, operationeel risico en concurrentiepositie.</p>
        <div class="hero-stats">
          <div class="stat">
            <div class="stat-num">100%</div>
            <div class="stat-label">Onafhankelijk</div>
          </div>
          <div class="stat">
            <div class="stat-num">Q2 2026</div>
            <div class="stat-label">NIS2 Wet NL</div>
          </div>
          <div class="stat">
            <div class="stat-num">Gratis</div>
            <div class="stat-label">Altijd toegankelijk</div>
          </div>
        </div>
      </div>
    </section>

    <div class="signal">
      <div class="signal-inner">
        <div class="signal-icon">🛡️</div>
        <div class="signal-text"><strong>NIS2 Cyberbeveiligingswet — verwacht Q2 2026.</strong> Slechts 14% van Nederlandse organisaties is goed voorbereid. Wat betekent dit voor uw aansprakelijkheid als bestuurder?</div>
      </div>
    </div>

    <section class="topics">
      <div class="topics-inner">
        <h2>Wat wij voor u verkennen</h2>
        <p>Praktische gidsen en analyse voor het Nederlandse MKB.</p>
        <div class="topics-grid">
          <a href="/nis2" class="topic-card featured">
            <div class="topic-tag">Urgent · 2026</div>
            <h3>NIS2 Compliance</h3>
            <p>Bestuurdersaansprakelijkheid, boetes en wat uw bedrijf nu moet regelen.</p>
            <div class="topic-status">Live</div>
          </a>
          <div class="topic-card">
            <div class="topic-tag">Strategie</div>
            <h3>AI voor het MKB</h3>
            <p>Welke AI-tools leveren daadwerkelijk ROI — en welke niet.</p>
          </div>
          <div class="topic-card">
            <div class="topic-tag">Operations</div>
            <h3>CRM Software</h3>
            <p>Welk CRM schaalt mee met uw groei zonder de overhead.</p>
          </div>
          <div class="topic-card">
            <div class="topic-tag">Verplight · 2026</div>
            <h3>E-facturatie</h3>
            <p>Verplichting voor overheidscontracten. Wat u nu moet regelen.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="newsletter">
      <div class="nl-inner">
        <div class="nl-copy">
          <h2>Blijf voorop. Zonder ruis.</h2>
          <p>Tweewekelijkse briefing voor bestuurders: wat er verandert in tech-regulering, welke tools het waard zijn en wat uw concurrenten al doen.</p>
          <ul class="nl-promises">
            <li>NIS2 & EU AI Act updates</li>
            <li>Onafhankelijke tool-analyses</li>
            <li>Leestijd: max. 4 minuten</li>
          </ul>
        </div>
        <form class="nl-form" id="newsletter-form" action="/api/subscribe" method="POST" novalidate>
          <div class="form-field">
            <label for="nl-email" class="form-label">E-mailadres</label>
            <input id="nl-email" name="email" type="email" placeholder="u@bedrijf.nl" required />
          </div>
          <div class="form-field">
            <label for="nl-role" class="form-label">Uw rol</label>
            <select id="nl-role" name="role">
              <option value="">— Optioneel —</option>
              <option value="bestuurder">Bestuurder/CEO</option>
              <option value="cfo">CFO/Controller</option>
              <option value="cto">CTO/IT Director</option>
              <option value="investor">Investor</option>
              <option value="other">Overig</option>
            </select>
          </div>
          <button type="submit">Aanmelden voor de briefing →</button>
          <div id="nl-msg"></div>
        </form>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <p>&copy; 2026 MKBTechGids. Alle rechten voorbehouden.</p>
    </div>
  </footer>

  <script>
    const toggle = document.querySelector('.nav-toggle');
    const menu = document.getElementById('mobile-menu');
    if(toggle && menu) {
      toggle.addEventListener('click', () => {
        const isOpen = !menu.hasAttribute('hidden');
        menu[isOpen ? 'setAttribute' : 'removeAttribute']('hidden', '');
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    const form = document.getElementById('newsletter-form');
    const msg = document.getElementById('nl-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      btn.disabled = true;
      btn.textContent = 'Moment...';
      try {
        const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
        const data = await res.json();
        msg.textContent = data.message;
        msg.style.color = data.success ? '#15803d' : '#ef4444';
        if(data.success) form.reset();
      } catch {
        msg.textContent = 'Er ging iets mis. Probeer het opnieuw.';
        msg.style.color = '#ef4444';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Aanmelden voor de briefing →';
      }
    });
  </script>
</body>
</html>
