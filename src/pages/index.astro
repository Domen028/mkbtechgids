---
// src/pages/index.astro
// Compatible with output: "server" + @astrojs/vercel adapter
// prerender: true tells Astro to statically generate this page at build time
export const prerender = true;

import Hero from '../components/Hero.astro';
import MethodStrip from '../components/MethodStrip.astro';
import Topics from '../components/Topics.astro';
import TechLeadCrosslink from '../components/TechLeadCrosslink.astro';
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Onafhankelijke analyses van tech-regulering, software en digitale strategie voor Nederlandse bestuurders, CFO's en investeerders. Geen jargon. Wel het eerlijke beeld." />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#15803d" />
  <link rel="canonical" href="https://www.mkbtechgids.nl/" />

  <!-- OG -->
  <meta property="og:title"       content="MKBTechGids — Technologiegids voor het Nederlandse MKB" />
  <meta property="og:description" content="Onafhankelijke analyses van tech-regulering, software en digitale strategie voor Nederlandse bestuurders, CFO's en investeerders." />
  <meta property="og:url"         content="https://www.mkbtechgids.nl/" />
  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="nl_NL" />
  <meta property="og:site_name"   content="MKBTechGids" />
  <meta name="twitter:card"       content="summary_large_image" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "MKBTechGids",
    "url": "https://www.mkbtechgids.nl",
    "description": "Onafhankelijke techgids voor Nederlandse MKB-bestuurders, CFO's en investeerders.",
    "inLanguage": "nl-NL"
  }
  </script>

  <title>MKBTechGids — Technologiegids voor het Nederlandse MKB</title>

  <style>
    /* ── Design tokens ─────────────────────────────── */
    :root {
      --g1:#f0fdf4; --g2:#bbf7d0; --g4:#15803d; --g5:#14532d;
      --n4:#0d1d3a; --n5:#182030;
      --s1:#f8fafc; --s2:#e2e8f0; --s3:#94a3b8; --s4:#475569; --s5:#1e293b;
      --a3:#fbbf24;
      --bg-dark:var(--n5); --bg-deeper:var(--n4);
      --bg-light:var(--s1); --bg-white:#ffffff; --primary:var(--g4);
      --font-display:'Playfair Display',Georgia,serif;
      --font-body:'Source Sans 3','Segoe UI',system-ui,sans-serif;
      --r-xs:4px; --r-sm:6px; --r-md:10px; --r-lg:14px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--font-body);background:var(--bg-light);color:var(--s5);line-height:1.6;-webkit-font-smoothing:antialiased;}
    a{color:inherit;text-decoration:none;}
    img,svg{display:block;max-width:100%;}
    .container{max-width:1100px;margin:0 auto;padding:0 28px;}
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}
    .skip-link{position:absolute;top:-100%;left:12px;background:var(--g4);color:#fff;padding:8px 16px;border-radius:var(--r-sm);font-size:14px;font-weight:600;z-index:9999;transition:top .15s;}
    .skip-link:focus{top:12px;}
  </style>
</head>
<body>
  <a class="skip-link" href="#main">Ga naar inhoud</a>

  <!-- ── HEADER ── -->
  <header class="site-header">
    <div class="header-inner container">
      <a href="/" class="nav-logo" aria-label="MKBTechGids — home">
        <svg viewBox="0 0 112 84" height="48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <text x="0" y="28" font-family="'Playfair Display',Georgia,serif" font-weight="700" font-size="29" fill="#182030">MKB</text>
          <text x="0" y="56" font-family="'Playfair Display',Georgia,serif" font-weight="700" font-size="29" fill="#15803d">Tech</text>
          <text x="0" y="84" font-family="'Playfair Display',Georgia,serif" font-weight="700" font-size="29" fill="#182030">Gids</text>
        </svg>
      </a>
      <nav class="nav-links" aria-label="Hoofdnavigatie">
        <a href="/nis2">NIS2</a>
        <a href="/ai-governance">AI Governance</a>
        <a href="/ai-tools">AI Tools</a>
        <a href="/crm">CRM</a>
        <a href="/artikelen">Artikelen</a>
      </nav>
      <a href="/nis2" class="nav-cta">NIS2 gids →</a>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu" type="button">
        <span></span><span></span><span></span>
      </button>
    </div>
    <nav id="mobile-menu" class="mobile-menu" hidden>
      <a href="/nis2">NIS2</a><a href="/ai-governance">AI Governance</a>
      <a href="/ai-tools">AI Tools</a><a href="/crm">CRM</a>
      <a href="/artikelen">Artikelen</a>
      <a href="/nis2" class="mobile-cta">NIS2 gids lezen →</a>
    </nav>
  </header>

  <main id="main">
    <Hero />
    <MethodStrip />
    <Topics />

    <!-- Newsletter (wired to existing /api/subscribe) -->
    <section class="newsletter" aria-labelledby="nl-heading">
      <div class="nl-glow" aria-hidden="true"></div>
      <div class="container nl-inner">
        <div class="nl-copy">
          <h2 id="nl-heading" class="nl-title">Blijf voorop. Zonder ruis.</h2>
          <p class="nl-sub">Tweewekelijkse briefing voor bestuurders en investeerders: wat er verandert in tech-regulering, welke tools het waard zijn en wat uw concurrenten al doen. Geen spam. Opzeggen wanneer u wilt.</p>
          <ul class="nl-promises">
            <li><span class="pcheck" aria-hidden="true">✓</span> NIS2 &amp; EU AI Act updates</li>
            <li><span class="pcheck" aria-hidden="true">✓</span> Onafhankelijke tool-analyses</li>
            <li><span class="pcheck" aria-hidden="true">✓</span> Leestijd: max. 4 minuten</li>
          </ul>
        </div>
        <form class="nl-form" id="newsletter-form" action="/api/subscribe" method="POST" novalidate>
          <div class="form-field">
            <label for="nl-email" class="form-label">E-mailadres</label>
            <input id="nl-email" name="email" type="email" class="form-input" placeholder="u@bedrijf.nl" required autocomplete="email" />
          </div>
          <div class="form-field">
            <label for="nl-role" class="form-label">Uw rol <span class="form-optional">(optioneel)</span></label>
            <select id="nl-role" name="role" class="form-select">
              <option value="">Selecteer uw functie</option>
              <option value="ceo">CEO / Directeur</option>
              <option value="cfo">CFO / Financieel directeur</option>
              <option value="dga">DGA</option>
              <option value="investor">Investeerder / Aandeelhouder</option>
              <option value="board">Commissaris / RvB</option>
              <option value="other">Anders</option>
            </select>
          </div>
          <button type="submit" class="form-submit">Aanmelden voor de briefing →</button>
          <p id="nl-msg" class="form-msg" aria-live="polite"></p>
          <p class="form-privacy">Door u aan te melden gaat u akkoord met onze <a href="/privacy">privacyverklaring</a>.</p>
        </form>
      </div>
    </section>

    <TechLeadCrosslink />
  </main>

  <!-- ── FOOTER ── -->
  <footer class="site-footer">
    <div class="footer-main">
      <div class="container footer-inner">
        <div class="footer-brand">
          <a href="/" class="footer-logo">
            <svg viewBox="0 0 96 72" height="36" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <text x="0" y="23" font-family="'Playfair Display',Georgia,serif" font-weight="700" font-size="23" fill="#182030">MKB</text>
              <text x="0" y="44" font-family="'Playfair Display',Georgia,serif" font-weight="700" font-size="23" fill="#15803d">Tech</text>
              <text x="0" y="65" font-family="'Playfair Display',Georgia,serif" font-weight="700" font-size="23" fill="#182030">Gids</text>
            </svg>
          </a>
          <p class="footer-tagline">De route al verkend.</p>
          <p class="footer-desc">Onafhankelijke techgids voor Nederlandse MKB-bestuurders, CFO's en investeerders.</p>
          <a href="https://www.linkedin.com/company/mkbtechgids" class="footer-linkedin" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7H10v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
        </div>
        <nav class="footer-nav">
          <div class="footer-col">
            <p class="footer-col-title">Onderwerpen</p>
            <ul>
              <li><a href="/nis2">NIS2 Compliance</a></li>
              <li><a href="/ai-governance">AI Governance</a></li>
              <li><a href="/ai-tools">AI Tools</a></li>
              <li><a href="/crm">CRM Software</a></li>
              <li><a href="/e-facturatie">E-facturatie</a></li>
              <li><a href="/boekhouding">Boekhoudsoftware</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">Over ons</p>
            <ul>
              <li><a href="/over">Over MKBTechGids</a></li>
              <li><a href="/methodologie">Methodologie</a></li>
              <li><a href="/artikelen">Artikelen</a></li>
              <li><a href="/privacy">Privacyverklaring</a></li>
              <li><a href="/affiliate-disclosure">Affiliate disclosure</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <p class="footer-col-title">Fractional Leadership</p>
            <p class="footer-partner-text">Heeft uw organisatie een fractional CTO, CIO of Chief Architect nodig?</p>
            <a href="https://techleadnl.nl" class="footer-partner-link" rel="noopener">TechLead NL →</a>
          </div>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <p class="footer-copy">© {new Date().getFullYear()} MKBTechGids. Alle rechten voorbehouden.</p>
        <p class="footer-affiliate-note">Deze site bevat affiliate-links. Wij ontvangen mogelijk een vergoeding bij aankoop, zonder meerkosten voor u. Dit heeft geen invloed op onze beoordelingen.</p>
      </div>
    </div>
  </footer>

  <!-- Nav toggle script -->
  <script>
    const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
    const menu   = document.getElementById('mobile-menu') as HTMLElement;
    toggle?.addEventListener('click', () => {
      const open = !menu.hidden;
      menu.hidden = open;
      toggle.setAttribute('aria-expanded', String(!open));
    });

    // Newsletter AJAX — keeps existing /api/subscribe endpoint
    const form = document.getElementById('newsletter-form') as HTMLFormElement;
    const msg  = document.getElementById('nl-msg') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Moment...';
      try {
        const res  = await fetch('/api/subscribe', { method:'POST', body: new FormData(form) });
        const data = await res.json();
        msg.textContent = data.message;
        msg.style.color = data.success ? 'var(--g2)' : '#f87171';
        if (data.success) form.reset();
      } catch {
        msg.textContent = 'Er ging iets mis. Probeer het opnieuw.';
        msg.style.color = '#f87171';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Aanmelden voor de briefing →';
      }
    });
  </script>

  <style>
    /* ── Header ── */
    .site-header{position:sticky;top:0;z-index:200;background:var(--s1);border-bottom:1px solid var(--s2);box-shadow:0 1px 6px rgba(24,32,48,.07);}
    .header-inner{display:flex;align-items:center;gap:36px;height:68px;}
    .nav-logo{flex-shrink:0;display:flex;align-items:center;}
    .nav-links{display:flex;gap:28px;flex:1;}
    .nav-links a{font-size:13.5px;font-weight:500;color:var(--s4);letter-spacing:.01em;padding:4px 0;border-bottom:2px solid transparent;transition:color .14s,border-color .14s;}
    .nav-links a:hover{color:var(--g4);border-bottom-color:var(--g4);}
    .nav-cta{flex-shrink:0;font-size:13px;font-weight:600;color:#fff;background:var(--g4);border-radius:var(--r-sm);padding:8px 18px;transition:background .14s,transform .14s;}
    .nav-cta:hover{background:var(--g5);transform:translateY(-1px);}
    .nav-toggle{display:none;flex-direction:column;justify-content:center;gap:5px;background:none;border:none;cursor:pointer;padding:6px;margin-left:auto;}
    .nav-toggle span{display:block;width:22px;height:2px;background:var(--s4);border-radius:2px;}
    .mobile-menu{display:flex;flex-direction:column;background:var(--s1);border-top:1px solid var(--s2);padding:8px 28px 20px;}
    .mobile-menu a{font-size:15px;font-weight:500;color:var(--s4);padding:12px 0;border-bottom:1px solid var(--s2);}
    .mobile-menu a:last-child{border-bottom:none;}
    .mobile-cta{display:inline-block;margin-top:10px;background:var(--g4);color:#fff!important;padding:11px 20px!important;border-radius:var(--r-sm);border-bottom:none!important;font-size:14px!important;text-align:center;font-weight:600!important;}
    @media(max-width:820px){.nav-links,.nav-cta{display:none}.nav-toggle{display:flex}}

    /* ── Newsletter ── */
    .newsletter{background:var(--bg-dark);padding:76px 0;position:relative;overflow:hidden;}
    .nl-glow{position:absolute;left:-120px;top:-120px;width:520px;height:520px;background:radial-gradient(circle,rgba(21,128,61,.09) 0%,transparent 70%);pointer-events:none;}
    .nl-inner{display:grid;grid-template-columns:1fr 1fr;gap:68px;align-items:start;position:relative;z-index:1;}
    .nl-title{font-family:var(--font-display);font-size:clamp(22px,3vw,30px);font-weight:700;color:var(--g1);letter-spacing:-.02em;margin-bottom:14px;}
    .nl-sub{font-size:15px;line-height:1.78;color:var(--s3);margin-bottom:22px;}
    .nl-promises{list-style:none;display:flex;flex-direction:column;gap:9px;}
    .nl-promises li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--s3);}
    .pcheck{color:var(--g4);font-weight:700;}
    .nl-form{display:flex;flex-direction:column;gap:16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:var(--r-lg);padding:30px 26px;}
    .form-field{display:flex;flex-direction:column;gap:6px;}
    .form-label{font-size:11.5px;font-weight:600;color:var(--s3);letter-spacing:.04em;text-transform:uppercase;}
    .form-optional{font-weight:400;color:var(--s4);text-transform:none;letter-spacing:0;}
    .form-input,.form-select{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.10);border-radius:var(--r-sm);padding:11px 14px;font-size:14px;color:var(--g1);font-family:var(--font-body);width:100%;transition:border-color .14s,background .14s;}
    .form-input::placeholder{color:var(--s4);}
    .form-input:focus,.form-select:focus{outline:none;border-color:var(--g4);background:rgba(21,128,61,.07);}
    .form-select option{background:var(--n5);color:var(--g1);}
    .form-submit{background:var(--g4);color:#fff;font-size:14px;font-weight:600;font-family:var(--font-body);padding:13px 20px;border:none;border-radius:var(--r-sm);cursor:pointer;letter-spacing:.01em;margin-top:4px;transition:background .14s,transform .14s;}
    .form-submit:hover{background:var(--g5);transform:translateY(-1px);}
    .form-submit:disabled{opacity:.7;cursor:not-allowed;transform:none;}
    .form-msg{font-size:13px;text-align:center;min-height:18px;}
    .form-privacy{font-size:11px;color:var(--s4);text-align:center;line-height:1.5;}
    .form-privacy a{color:var(--s3);text-decoration:underline;}
    @media(max-width:820px){.nl-inner{grid-template-columns:1fr;gap:36px}}

    /* ── Footer ── */
    .site-footer{background:var(--s1);border-top:1px solid var(--s2);}
    .footer-main{padding:56px 0 48px;}
    .footer-inner{display:grid;grid-template-columns:260px 1fr;gap:64px;align-items:start;}
    .footer-logo{display:inline-block;margin-bottom:10px;}
    .footer-tagline{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--g4);margin-bottom:8px;}
    .footer-desc{font-size:13.5px;color:var(--s4);line-height:1.65;max-width:220px;margin-bottom:16px;}
    .footer-linkedin{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:var(--s4);transition:color .14s;}
    .footer-linkedin:hover{color:var(--g4);}
    .footer-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}
    .footer-col-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--s5);margin-bottom:14px;}
    .footer-col ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:9px;}
    .footer-col ul a{font-size:13.5px;color:var(--s4);transition:color .12s;}
    .footer-col ul a:hover{color:var(--g4);}
    .footer-partner-text{font-size:13px;color:var(--s4);line-height:1.62;margin-bottom:12px;}
    .footer-partner-link{display:inline-flex;align-items:center;gap:4px;font-size:13px;font-weight:600;color:var(--g4);transition:color .12s;}
    .footer-partner-link:hover{color:var(--g5);}
    .footer-bottom{border-top:1px solid var(--s2);background:var(--s2);}
    .footer-bottom-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;padding-top:14px;padding-bottom:14px;flex-wrap:wrap;}
    .footer-copy{font-size:12px;color:var(--s4);white-space:nowrap;}
    .footer-affiliate-note{font-size:11.5px;color:var(--s3);line-height:1.5;max-width:540px;text-align:right;}
    @media(max-width:900px){.footer-inner{grid-template-columns:1fr;gap:36px}.footer-nav{grid-template-columns:1fr 1fr}}
    @media(max-width:560px){.footer-nav{grid-template-columns:1fr}.footer-bottom-inner{flex-direction:column;align-items:flex-start}.footer-affiliate-note{text-align:left}}
  </style>
</body>
</html>
