---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="MKBTechGids"
  description="Onafhankelijke technologiegids voor het Nederlandse MKB"
>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">● Onafhankelijk · Geen advertenties · Nederlands MKB</div>
      <h1>Technologie beslist mee.<br><em>Of u het ziet of niet.</em></h1>
      <p>Voor bestuurders, CFO's en investeerders die willen begrijpen wat technologiekeuzes werkelijk betekenen voor bedrijfswaarde, operationeel risico en concurrentiepositie.</p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">100%</div>
          <div class="stat-label">Onafhankelijk</div>
        </div>
        <div class="stat">
          <div class="stat-num">Q2 2026</div>
          <div class="stat-label">NIS2 Wet NL</div>
        </div>
        <div class="stat">
          <div class="stat-num">Gratis</div>
          <div class="stat-label">Altijd toegankelijk</div>
        </div>
      </div>
    </div>
  </section>

  <div class="signal">
    <div class="signal-inner">
      <div class="signal-icon">🛡️</div>
      <div class="signal-text">
        <strong><a href="/nis2" style="color: inherit; text-decoration: underline;">NIS2 Cyberbeveiligingswet — verwacht Q2 2026.</a></strong>
        Slechts 14% van Nederlandse organisaties is goed voorbereid.
        Wat betekent dit voor uw aansprakelijkheid als bestuurder?
      </div>
    </div>
  </div>

  <section class="topics">
    <div class="topics-inner">
      <h2>Wat wij voor u verkennen</h2>
      <p class="topics-desc">Praktische gidsen en analyse voor het Nederlandse MKB.</p>
      <div class="topics-grid">
        <a href="/nis2" class="topic-card featured">
          <div class="topic-tag">Urgent · 2026</div>
          <h3>NIS2 Implementatie</h3>
          <p><strong>2 praktische artikelen:</strong> begrip van regelgeving + stap-voor-stap implementatie met tools en roadmap.</p>
          <div class="topic-status">Live</div>
        </a>
        <div class="topic-card">
          <div class="topic-tag">Strategie</div>
          <h3>AI voor het MKB</h3>
          <p>Welke AI-tools leveren daadwerkelijk ROI — en welke niet.</p>
        </div>
        <div class="topic-card">
          <div class="topic-tag">Operations</div>
          <h3>CRM Software</h3>
          <p>Welk CRM schaalt mee met uw groei zonder de overhead.</p>
        </div>
        <div class="topic-card">
          <div class="topic-tag">Verplicht · 2026</div>
          <h3>E-facturatie</h3>
          <p>Verplichting voor overheidscontracten. Wat u nu moet regelen.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="newsletter">
    <div class="nl-inner">
      <div class="nl-copy">
        <h2>Blijf voorop. Zonder ruis.</h2>
        <p>Tweewekelijkse briefing voor bestuurders: wat er verandert in tech-regulering, welke tools het waard zijn en wat uw concurrenten al doen.</p>
        <ul class="nl-promises">
          <li>NIS2 & EU AI Act updates</li>
          <li>Onafhankelijke tool-analyses</li>
          <li>Leestijd: max. 4 minuten</li>
        </ul>
      </div>
      <form class="nl-form" id="newsletter-form" action="/api/subscribe" method="POST" novalidate>
        <div class="form-field">
          <label for="nl-email" class="form-label">E-mailadres</label>
          <input id="nl-email" name="email" type="email" placeholder="u@bedrijf.nl" required />
        </div>
        <div class="form-field">
          <label for="nl-role" class="form-label">Uw rol</label>
          <select id="nl-role" name="role">
            <option value="">— Optioneel —</option>
            <option value="bestuurder">Bestuurder/CEO</option>
            <option value="cfo">CFO/Controller</option>
            <option value="cto">CTO/IT Director</option>
            <option value="investor">Investor</option>
            <option value="other">Overig</option>
          </select>
        </div>
        <button type="submit">Aanmelden voor de briefing →</button>
        <p class="nl-social-proof"><i class="ti ti-users"></i> Meer dan 340 bestuurders gingen u voor.</p>
        <div id="nl-msg"></div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
/* ── Hero ───────────────────────────────────────────── */
.hero {
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy-light) 100%);
  padding: 120px 28px;
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
  background-size: 32px 32px; pointer-events: none;
}
.hero-inner { position: relative; max-width: 700px; margin: 0 auto; }
.hero-badge {
  display: inline-block; border: 1px solid var(--green); border-radius: var(--radius-sm);
  padding: 8px 16px; margin-bottom: 24px;
  font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
  color: var(--text-dark);
}
.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(40px, 6vw, 56px); font-weight: 700;
  color: var(--text-dark); line-height: 1.1; margin-bottom: 20px;
}
.hero h1 em { font-style: normal; color: var(--green-light); }
.hero p { font-size: 16px; color: var(--text-light); line-height: 1.8; margin-bottom: 32px; max-width: 600px; }
.hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 60px; }
.stat { border-left: 2px solid var(--green-light); padding-left: 20px; }
.stat-num { font-size: 36px; font-weight: 700; color: var(--green-light); }
.stat-label { font-size: 12px; color: var(--text-light); text-transform: uppercase; margin-top: 8px; }

/* ── Signal strip ───────────────────────────────────── */
.signal { background: var(--navy-dark); border-top: 2px solid var(--green-light); padding: 16px 28px; }
.signal-inner { max-width: var(--max-width); margin: 0 auto; display: flex; align-items: center; gap: 16px; }
.signal-icon {
  width: 48px; height: 48px; flex-shrink: 0;
  background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
  border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;
  font-size: 24px;
}
.signal-text { font-size: 14px; font-weight: 500; color: var(--text-dark); }

/* ── Topics ─────────────────────────────────────────── */
.topics { padding: var(--space-3xl) 28px; background: var(--s1); }
.topics-inner { max-width: var(--max-width); margin: 0 auto; }
.topics h2 { font-size: 32px; margin-bottom: 12px; color: var(--navy-dark); }
.topics-desc { font-size: 16px; color: var(--s4); margin-bottom: 48px; max-width: 700px; }
.topics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 28px; }
.topic-card {
  background: var(--white); border: 2px solid var(--bg-gray);
  border-radius: var(--radius-md); padding: 28px;
  transition: all 0.2s; text-decoration: none; display: block; color: inherit;
}
.topic-card.featured { background: var(--green-bg); border-color: var(--green); }
.topic-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.topic-tag {
  display: inline-block; background: rgba(20,83,45,0.1); color: var(--green);
  padding: 4px 10px; border-radius: var(--radius-sm);
  font-size: 10px; font-weight: 600; text-transform: uppercase; margin-bottom: 12px;
}
.topic-card.featured .topic-tag { background: rgba(20,83,45,0.2); }
.topic-card h3 { font-size: 18px; color: var(--navy-dark); margin-bottom: 12px; }
.topic-card p { font-size: 14px; color: var(--s4); line-height: 1.7; }
.topic-status { display: inline-block; margin-top: 16px; font-size: 13px; font-weight: 600; color: var(--green-light); }
.topic-status::before { content: '●'; margin-right: 6px; }

/* ── Newsletter ─────────────────────────────────────── */
.newsletter { background: var(--navy-dark); padding: var(--space-3xl) 28px; position: relative; overflow: hidden; }
.nl-inner { max-width: var(--max-width); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
.nl-copy h2 { font-size: 28px; color: var(--text-dark); margin-bottom: 16px; }
.nl-copy p { font-size: 15px; color: var(--text-light); line-height: 1.8; margin-bottom: 20px; }
.nl-promises { list-style: none; margin: 0; padding: 0; }
.nl-promises li { font-size: 14px; color: var(--text-light); padding: 8px 0 8px 24px; position: relative; }
.nl-promises li::before { content: '✓'; position: absolute; left: 0; color: var(--green-light); font-weight: 700; }
.nl-form { display: flex; flex-direction: column; gap: 16px; }
.form-field { display: flex; flex-direction: column; gap: 10px; }
.form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); }
.nl-form input,
.nl-form select {
  background: rgba(255,255,255,0.95); border: 1px solid var(--s2);
  border-radius: var(--radius-sm); padding: 14px; font-size: 15px; font-family: inherit;
  height: 48px; line-height: 1.2;
}
.nl-form input:focus,
.nl-form select:focus { outline: none; border-color: var(--green-light); box-shadow: 0 0 0 2px rgba(21,128,61,0.1); }
.nl-form select {
  appearance: none;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23475569' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat: no-repeat; background-position: right 10px center; background-size: 20px; padding-right: 36px;
}
.nl-form button {
  background: var(--green-light); color: var(--white); border: none;
  border-radius: var(--radius-sm); padding: 14px 24px; font-size: 15px; font-weight: 600;
  cursor: pointer; transition: background 0.14s; height: 48px; line-height: 1.2;
  display: flex; align-items: center; justify-content: center;
}
.nl-form button:hover { background: var(--green); }
.nl-msg { font-size: 13px; margin-top: 12px; min-height: 20px; }
.nl-social-proof { font-size: 12px; color: var(--green); display: flex; align-items: center; gap: 6px; margin-top: 2px; }

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 768px) {
  .hero { padding: 80px 28px; }
  .hero h1 { font-size: 32px; }
  .hero-stats { grid-template-columns: 1fr; gap: 24px; }
  .nl-inner { grid-template-columns: 1fr; gap: 40px; }
  .topics-grid { grid-template-columns: 1fr; }
  .signal-inner { flex-direction: column; text-align: center; }
}
</style>

<script>
const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
const msg = document.getElementById('nl-msg');
form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = form.querySelector('button') as HTMLButtonElement;
  btn.disabled = true;
  btn.textContent = 'Moment...';
  try {
    const res = await fetch('/api/subscribe', { method: 'POST', body: new FormData(form) });
    const data = await res.json();
    if (msg) {
      msg.textContent = data.message;
      msg.style.color = data.success ? '#15803d' : '#ef4444';
    }
    if (data.success) form.reset();
  } catch {
    if (msg) { msg.textContent = 'Er ging iets mis. Probeer het opnieuw.'; msg.style.color = '#ef4444'; }
  } finally {
    btn.disabled = false;
    btn.textContent = 'Aanmelden voor de briefing →';
  }
});
</script>
