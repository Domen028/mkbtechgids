  <style>
    :root {
      --navy-dark: #0f2147;
      --navy-light: #1e3a6e;
      --green: #14532d;
      --green-light: #15803d;
      --green-bg: #f0fdf4;
      --text-dark: #f1f5f9;
      --text-light: #94a3b8;
      --bg-light: #f8fafc;
      --bg-gray: #e2e8f0;
      --text-body: #475569;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Source Sans 3', sans-serif; background: var(--bg-light); color: var(--text-body); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    img, svg { display: block; max-width: 100%; }

    .site-header { position: sticky; top: 0; z-index: 200; background: var(--bg-light); border-bottom: 1px solid var(--bg-gray); }
    .header-inner { display: flex; align-items: center; gap: 36px; height: 68px; max-width: 1100px; margin: 0 auto; padding: 0 28px; }
    .nav-logo { flex-shrink: 0; display: flex; align-items: center; }
    .nav-logo img { height: 46px; width: auto; }
    .nav-links { display: flex; gap: 28px; flex: 1; margin: 0; padding: 0; }
    .nav-links a { font-size: 13.5px; font-weight: 500; color: var(--text-body); padding: 4px 0; border-bottom: 2px solid transparent; transition: color 0.14s; }
    .nav-links a:hover { color: var(--green); border-bottom-color: var(--green); }
    .nav-item { position: relative; display: flex; align-items: center; }
    .nav-dropdown-trigger { background: none; border: none; font-family: inherit; font-size: 13.5px; font-weight: 500; color: var(--text-body); padding: 4px 0; cursor: pointer; display: flex; align-items: center; gap: 6px; border-bottom: 2px solid transparent; transition: color 0.14s; }
    .nav-dropdown-trigger:hover { color: var(--green); border-bottom-color: var(--green); }
    .nav-dropdown-trigger::after { content: '▼'; font-size: 8px; }
    .nav-dropdown { position: absolute; top: calc(100% + 12px); left: -40px; background: white; border: 1px solid var(--bg-gray); border-radius: 6px; min-width: 360px; padding: 8px 0; box-shadow: 0 8px 24px rgba(15,33,71,0.15); display: none; z-index: 1000; }
    .nav-dropdown.open { display: block; }
    .nav-dropdown a { display: block; padding: 14px 20px; font-size: 14px; color: var(--text-body); transition: all 0.14s; border-left: 3px solid transparent; }
    .nav-dropdown a:hover { background: var(--green-bg); color: var(--green); border-left-color: var(--green); }
    .nav-cta { font-size: 13px; font-weight: 600; color: white; background: var(--green); border-radius: 6px; padding: 8px 18px; text-decoration: none; transition: background 0.14s; }
    .nav-cta:hover { background: var(--green-light); }
    .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
    .nav-toggle span { display: block; width: 22px; height: 2px; background: var(--text-body); border-radius: 2px; }
    .mobile-menu { display: none; }
    .mobile-menu:not([hidden]) { display: flex; flex-direction: column; background: var(--bg-light); border-top: 1px solid var(--bg-gray); padding: 8px 28px 20px; }
    .mobile-menu a { font-size: 15px; font-weight: 500; color: var(--text-body); padding: 12px 0; border-bottom: 1px solid var(--bg-gray); }

    .article-hero { background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy-light) 100%); padding: 80px 28px; position: relative; overflow: hidden; }
    .article-hero::before { content: ''; position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px; pointer-events: none; }
    .article-hero-inner { position: relative; max-width: 760px; margin: 0 auto; }
    .breadcrumb { font-size: 12px; color: var(--text-light); margin-bottom: 24px; display: flex; gap: 12px; align-items: center; }
    .article-tag { display: inline-block; background: rgba(20,83,45,0.2); border: 1px solid var(--green); color: var(--text-dark); padding: 6px 12px; border-radius: 4px; font-size: 10px; font-weight: 600; text-transform: uppercase; margin-bottom: 24px; }
    .article-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(30px, 5vw, 46px); font-weight: 700; color: var(--text-dark); line-height: 1.15; margin-bottom: 20px; }
    .article-hero h1 em { font-style: normal; color: #4ade80; }
    .article-hero p { font-size: 16px; color: var(--text-light); line-height: 1.8; margin-bottom: 24px; }
    .article-meta { font-size: 12px; color: var(--text-light); display: flex; gap: 20px; }

    .signal-strip { background: #0a1628; border-top: 2px solid var(--green); padding: 20px 28px; }
    .signal-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; gap: 16px; }
    .signal-dot { width: 8px; height: 8px; background: #4ade80; border-radius: 50%; flex-shrink: 0; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
    .signal-text { font-size: 14px; font-weight: 600; color: var(--text-dark); }

    .article-content { background: white; padding: 60px 28px; }
    .article-inner { max-width: 760px; margin: 0 auto; }
    h2 { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--navy-dark); margin-top: 52px; margin-bottom: 20px; line-height: 1.2; }
    p { margin-bottom: 18px; color: var(--text-body); line-height: 1.8; }
    strong { color: var(--navy-dark); font-weight: 600; }

    .alert-box { background: #fff7ed; border-left: 4px solid #ea580c; padding: 24px; border-radius: 6px; margin: 32px 0; }
    .alert-box strong { color: #9a3412; display: block; margin-bottom: 8px; font-size: 15px; }

    .scope-box { background: var(--green-bg); border: 2px solid var(--green); border-radius: 8px; padding: 28px 32px; margin: 32px 0; }
    .scope-box h3 { font-weight: 700; color: var(--green); margin-bottom: 16px; font-size: 15px; text-transform: uppercase; letter-spacing: 0.5px; }
    .scope-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .scope-item { background: white; border: 1px solid #bbf7d0; border-radius: 6px; padding: 20px; }
    .scope-item h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 10px; font-size: 14px; }
    .scope-item p { font-size: 14px; margin-bottom: 6px; }
    .scope-note { font-size: 13px; color: var(--text-body); margin-top: 16px; padding-top: 16px; border-top: 1px solid #bbf7d0; }
    .scope-link { display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; font-size: 14px; font-weight: 600; color: var(--green); background: white; border: 1px solid var(--green); padding: 10px 18px; border-radius: 6px; transition: all 0.14s; }
    .scope-link:hover { background: var(--green); color: white; }

    .checklist-box { background: white; border: 2px solid var(--bg-gray); border-radius: 8px; padding: 8px 0; margin: 32px 0; }
    .check-item { display: flex; gap: 16px; align-items: flex-start; padding: 20px 28px; border-bottom: 1px solid var(--bg-gray); transition: background 0.14s; }
    .check-item:last-child { border-bottom: none; }
    .check-item:hover { background: var(--green-bg); }
    .check-number { background: var(--navy-dark); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; flex-shrink: 0; margin-top: 2px; }
    .check-content h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 6px; font-size: 15px; }
    .check-content p { font-size: 14px; color: var(--text-body); margin-bottom: 0; }

    .timeline-table { width: 100%; border-collapse: collapse; margin: 28px 0; border-radius: 8px; overflow: hidden; border: 1px solid var(--bg-gray); }
    .timeline-table th { background: var(--navy-dark); color: white; padding: 14px 20px; text-align: left; font-size: 13px; font-weight: 600; }
    .timeline-table td { padding: 14px 20px; border-bottom: 1px solid var(--bg-gray); font-size: 14px; }
    .timeline-table tr:last-child td { border-bottom: none; }
    .timeline-table tr:nth-child(even) td { background: var(--bg-light); }
    .badge-urgent { display: inline-block; background: #fee2e2; color: #991b1b; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 12px; }
    .badge-warning { display: inline-block; background: #fef3c7; color: #92400e; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 12px; }
    .badge-info { display: inline-block; background: #dbeafe; color: #1e40af; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 12px; }

    .fines-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 28px 0; }
    .fine-box { border-radius: 8px; padding: 28px; text-align: center; }
    .fine-box.essential { background: #fef2f2; border: 2px solid #fca5a5; }
    .fine-box.important { background: #fef9c3; border: 2px solid #fde047; }
    .fine-box h4 { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .fine-box.essential h4 { color: #991b1b; }
    .fine-box.important h4 { color: #854d0e; }
    .fine-amount { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; margin-bottom: 6px; }
    .fine-box.essential .fine-amount { color: #dc2626; }
    .fine-box.important .fine-amount { color: #b45309; }
    .fine-sub { font-size: 13px; color: var(--text-body); }

    .overlap-box { background: #f0f9ff; border: 2px solid #7dd3fc; border-radius: 8px; padding: 28px 32px; margin: 32px 0; }
    .overlap-box h3 { font-weight: 700; color: #1e40af; margin-bottom: 16px; font-size: 16px; }
    .overlap-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #bae6fd; }
    .overlap-item:last-child { border-bottom: none; }
    .overlap-label { font-size: 14px; color: var(--text-body); }
    .overlap-pct { font-weight: 700; color: #1d4ed8; font-size: 18px; }

    .cost-box { background: var(--navy-dark); color: white; border-radius: 8px; padding: 32px; margin: 32px 0; }
    .cost-box h3 { font-family: 'Playfair Display', serif; font-size: 20px; color: var(--text-dark); margin-bottom: 20px; }
    .cost-row { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 14px; }
    .cost-row:last-child { border-bottom: none; padding-top: 16px; }
    .cost-label { color: var(--text-light); }
    .cost-value { font-weight: 700; }
    .cost-value.danger { color: #f87171; }
    .cost-value.success { color: #4ade80; }
    .cost-value.highlight { color: white; font-size: 18px; }

    .cta-section { background: var(--green); color: white; padding: 48px 36px; border-radius: 8px; margin: 56px 0; text-align: center; }
    .cta-section h3 { font-family: 'Playfair Display', serif; font-size: 24px; margin-bottom: 12px; }
    .cta-section p { opacity: 0.9; margin-bottom: 28px; font-size: 15px; line-height: 1.7; }
    .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .cta-btn-primary { display: inline-block; background: white; color: var(--green); font-weight: 700; padding: 14px 32px; border-radius: 6px; text-decoration: none; transition: all 0.14s; font-size: 15px; }
    .cta-btn-primary:hover { background: var(--green-bg); }
    .cta-btn-secondary { display: inline-block; background: transparent; color: white; font-weight: 600; padding: 14px 32px; border-radius: 6px; border: 2px solid rgba(255,255,255,0.6); text-decoration: none; transition: all 0.14s; font-size: 15px; }
    .cta-btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.1); }

    .related-box { background: var(--bg-light); border: 2px solid var(--bg-gray); border-radius: 8px; padding: 28px; margin: 32px 0; }
    .related-box h4 { font-weight: 700; color: var(--navy-dark); margin-bottom: 16px; font-size: 15px; }
    .related-link { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--bg-gray); text-decoration: none; color: var(--text-body); font-size: 14px; transition: color 0.14s; }
    .related-link:last-child { border-bottom: none; }
    .related-link:hover { color: var(--green); }
    .related-link::before { content: '→'; color: var(--green); font-weight: 700; }

    .sources-section { border-top: 1px solid var(--bg-gray); padding-top: 28px; margin-top: 48px; }
    .sources-section h4 { font-size: 13px; font-weight: 700; color: var(--navy-dark); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
    .sources-section p { font-size: 12px; color: var(--text-body); line-height: 1.7; }

    .footer { background: var(--navy-dark); color: var(--text-light); padding: 48px 28px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
    .footer-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
    .footer p { font-size: 13px; margin: 0; }
    .footer a { color: #4ade80; }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .nav-toggle { display: flex; margin-left: auto; }
      .article-hero { padding: 48px 20px; }
      .scope-grid { grid-template-columns: 1fr; }
      .fines-grid { grid-template-columns: 1fr; }
      .cta-buttons { flex-direction: column; }
    }
  </style>
</head>
