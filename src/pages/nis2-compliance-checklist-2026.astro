  <script>
    const toggle = document.querySelector('.nav-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const open = !menu.hasAttribute('hidden');
        menu[open ? 'setAttribute' : 'removeAttribute']('hidden', '');
        toggle.setAttribute('aria-expanded', String(!open));
      });
    }
    const trigger = document.querySelector('.nav-dropdown-trigger');
    const dropdown = document.querySelector('.nav-dropdown');
    if (trigger && dropdown) {
      trigger.addEventListener('click', e => {
        e.stopPropagation();
        dropdown.classList.toggle('open');
        trigger.setAttribute('aria-expanded', dropdown.classList.contains('open').toString());
      });
      document.addEventListener('click', () => { dropdown.classList.remove('open'); trigger.setAttribute('aria-expanded', 'false'); });
    }
  </script>
