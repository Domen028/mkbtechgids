---
// src/components/Topics.astro
const topics = [
  { tag:"Urgent · 2026",    name:"NIS2 Compliance",      desc:"Bestuurdersaansprakelijkheid, boetes en wat uw bedrijf nu moet regelen.",                          href:"/nis2",            live:true,  urgent:true  },
  { tag:"EU AI Act · 2026", name:"AI Governance",         desc:"Welke AI-implementaties zijn toegestaan en wat zijn uw verplichtingen als organisatie.",           href:"/ai-governance",   live:false, urgent:false },
  { tag:"Strategie",        name:"AI Tools voor het MKB", desc:"Welke AI-tools leveren aantoonbare ROI — en welke zijn marketing zonder meerwaarde.",              href:"/ai-tools",        live:false, urgent:false },
  { tag:"Operaties",        name:"CRM Software",          desc:"Welk CRM schaalt mee met uw groei zonder de TCO te laten ontsporen.",                              href:"/crm",             live:false, urgent:false },
  { tag:"Verplicht · 2026", name:"E-facturatie",          desc:"Peppol-verplicht voor overheidscontracten. Wat u nu moet inrichten.",                              href:"/e-facturatie",    live:false, urgent:false },
  { tag:"Financiën",        name:"Boekhoudsoftware",      desc:"Van Exact tot Moneybird: wat past bij uw schaal, sector en groeiambitie.",                         href:"/boekhouding",     live:false, urgent:false },
];
---

<section class="topics" aria-labelledby="topics-heading">
  <div class="container">
    <header class="topics-header">
      <p class="topics-eyebrow" id="topics-heading">Wat wij voor u verkennen</p>
      <p class="topics-sub">
        Onafhankelijke analyses op het snijvlak van technologie, regulering en bedrijfsvoering.
        Geschreven voor beslissers &mdash; niet voor IT-afdelingen.
      </p>
    </header>
    <ul class="topics-grid" role="list">
      {topics.map((t) => (
        <li>
          <a href={t.href}
            class={`topic-card ${t.urgent ? 'topic-urgent' : ''} ${!t.live ? 'topic-soon' : ''}`}
            aria-label={`${t.name} — ${t.live ? 'Nu beschikbaar' : 'Binnenkort'}`}
          >
            <span class="topic-tag">{t.tag}</span>
            <span class="topic-name">{t.name}</span>
            <span class="topic-desc">{t.desc}</span>
            {t.live
              ? <span class="topic-live-badge"><span class="live-dot" aria-hidden="true"></span>Live</span>
              : <span class="topic-soon-badge">Binnenkort</span>
            }
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
.topics { background: var(--bg-light); padding: 68px 0 76px; border-top: 1px solid var(--s2); }
.topics-header { max-width: 560px; margin-bottom: 36px; }
.topics-eyebrow { font-size:11px; font-weight:700; color:var(--s3); text-transform:uppercase; letter-spacing:0.09em; margin-bottom:10px; }
.topics-sub { font-size:15px; color:var(--s4); line-height:1.7; }
.topics-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px; list-style:none; padding:0; }
.topic-card {
  display:flex; flex-direction:column; gap:7px;
  background:var(--bg-white); border:0.5px solid var(--s2);
  border-radius:var(--r-md); padding:20px 18px 17px; height:100%;
  text-decoration:none;
  transition:border-color 0.15s,box-shadow 0.15s,transform 0.15s;
}
.topic-card:hover { border-color:rgba(21,128,61,0.32); box-shadow:0 5px 20px rgba(21,128,61,0.09); transform:translateY(-2px); }
.topic-urgent { background:var(--g1); border:1px solid rgba(21,128,61,0.22); }
.topic-urgent:hover { border-color:rgba(21,128,61,0.48); box-shadow:0 5px 24px rgba(21,128,61,0.15); }
.topic-soon { opacity:.82; }
.topic-soon:hover { opacity:1; }
.topic-tag { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:var(--g4); }
.topic-name { font-family:var(--font-display); font-size:16.5px; font-weight:700; color:var(--s5); line-height:1.2; }
.topic-desc { font-size:13px; color:var(--s4); line-height:1.58; flex:1; }
.topic-live-badge { display:inline-flex; align-items:center; gap:5px; margin-top:6px; font-size:11px; font-weight:700; color:var(--g4); text-transform:uppercase; letter-spacing:0.05em; }
.live-dot { width:6px; height:6px; border-radius:50%; background:var(--g4); animation:pulseLive 2.2s ease-in-out infinite; }
.topic-soon-badge { display:inline-block; margin-top:6px; font-size:10px; font-weight:600; color:var(--s3); background:var(--s2); border-radius:var(--r-xs); padding:2px 7px; text-transform:uppercase; letter-spacing:0.04em; }
@keyframes pulseLive { 0%,100%{opacity:1} 50%{opacity:.35} }
@media(max-width:640px){.topics-grid{grid-template-columns:1fr}}
</style>
