---
// Topics.astro — Topic cards grid with executive framing
const topics = [
  {
    tag: "Urgent · 2026",
    name: "NIS2 Compliance",
    desc: "Bestuurdersaansprakelijkheid, boetes en wat uw bedrijf nu moet regelen.",
    href: "/nis2",
    status: "live",
    urgent: true,
  },
  {
    tag: "EU AI Act · 2025–2026",
    name: "AI Governance",
    desc: "Welke AI-implementaties zijn toegestaan en wat zijn uw verplichtingen als organisatie.",
    href: "/ai-governance",
    status: "soon",
    urgent: false,
  },
  {
    tag: "Strategie",
    name: "AI Tools voor het MKB",
    desc: "Welke AI-tools leveren aantoonbare ROI — en welke zijn marketing zonder meerwaarde.",
    href: "/ai-tools",
    status: "soon",
    urgent: false,
  },
  {
    tag: "Operaties",
    name: "CRM Software",
    desc: "Welk CRM schaalt mee met uw groei zonder de TCO te laten ontsporen.",
    href: "/crm",
    status: "soon",
    urgent: false,
  },
  {
    tag: "Verplicht · 2026",
    name: "E-facturatie",
    desc: "Peppol-verplicht voor overheidscontracten. Wat u nu moet inrichten.",
    href: "/e-facturatie",
    status: "soon",
    urgent: false,
  },
  {
    tag: "Financiën",
    name: "Boekhoudsoftware",
    desc: "Van Exact tot Moneybird: wat past bij uw schaal, sector en groeiambitie.",
    href: "/boekhouding",
    status: "soon",
    urgent: false,
  },
];
---

<section class="topics" aria-labelledby="topics-heading">
  <div class="container">

    <div class="topics-header">
      <p class="topics-label" id="topics-heading">Wat wij voor u verkennen</p>
      <p class="topics-sub">
        Onafhankelijke analyses op het snijvlak van technologie, regulering en bedrijfsvoering.
        Geschreven voor beslissers — niet voor IT-afdelingen.
      </p>
    </div>

    <div class="topics-grid" role="list">
      {topics.map((t) => (
        <a
          href={t.href}
          class={`topic-card ${t.urgent ? 'topic-urgent' : ''} ${t.status === 'soon' ? 'topic-soon-card' : ''}`}
          role="listitem"
          aria-label={`${t.name} — ${t.status === 'live' ? 'Nu beschikbaar' : 'Binnenkort'}`}
        >
          <span class="topic-tag">{t.tag}</span>
          <span class="topic-name">{t.name}</span>
          <span class="topic-desc">{t.desc}</span>
          {t.status === 'live' ? (
            <span class="topic-live" aria-label="Nu beschikbaar">
              <span class="topic-live-dot" aria-hidden="true"></span>
              Live
            </span>
          ) : (
            <span class="topic-soon-badge">Binnenkort</span>
          )}
        </a>
      ))}
    </div>

  </div>
</section>

<style>
.topics {
  background: var(--s1);
  padding: 64px 0 72px;
  border-top: 1px solid var(--s2);
}

.topics-header {
  max-width: 560px;
  margin-bottom: 36px;
}
.topics-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--s3);
  text-transform: uppercase;
  letter-spacing: 0.09em;
  margin-bottom: 10px;
}
.topics-sub {
  font-size: 15px;
  color: var(--s4);
  line-height: 1.65;
}

.topics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 12px;
}

/* Base card */
.topic-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  background: var(--color-bg-white);
  border: 0.5px solid var(--s2);
  border-radius: var(--r-md);
  padding: 18px 18px 16px;
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  cursor: pointer;
}
.topic-card:hover {
  border-color: rgba(21,128,61,0.3);
  box-shadow: 0 4px 16px rgba(21,128,61,0.08);
  transform: translateY(-2px);
}

/* Urgent variant */
.topic-urgent {
  background: var(--g1);
  border: 1px solid rgba(21,128,61,0.22);
}
.topic-urgent:hover {
  border-color: rgba(21,128,61,0.45);
  box-shadow: 0 4px 20px rgba(21,128,61,0.14);
}

/* Soon variant — slightly muted */
.topic-soon-card { opacity: 0.82; }
.topic-soon-card:hover { opacity: 1; }

.topic-tag {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--g4);
}
.topic-name {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  color: var(--s5);
  line-height: 1.2;
}
.topic-desc {
  font-size: 13px;
  color: var(--s4);
  line-height: 1.55;
  flex: 1;
}

.topic-live {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  margin-top: 6px;
  font-size: 11px;
  font-weight: 700;
  color: var(--g4);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.topic-live-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--g4);
  animation: pulse 2s ease-in-out infinite;
}

.topic-soon-badge {
  display: inline-block;
  margin-top: 6px;
  font-size: 10px;
  font-weight: 600;
  color: var(--s3);
  background: var(--s2);
  border-radius: 4px;
  padding: 2px 7px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}

@media (max-width: 640px) {
  .topics-grid { grid-template-columns: 1fr; }
}
</style>
