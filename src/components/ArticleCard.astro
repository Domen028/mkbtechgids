---
// ArticleCard.astro
interface Props {
  title: string;
  excerpt: string;
  href: string;
  tag: string;
  date: string;
  readTime?: string;
  urgent?: boolean;
}
const { title, excerpt, href, tag, date, readTime = '5 min', urgent = false } = Astro.props;
---

<article class={`article-card ${urgent ? 'article-urgent' : ''}`}>
  <a href={href} class="article-card-link" aria-label={title}>
    <header class="article-card-header">
      <span class="article-tag">{tag}</span>
      {urgent && <span class="article-urgent-badge" aria-label="Urgent onderwerp">Urgent</span>}
    </header>
    <h3 class="article-title">{title}</h3>
    <p class="article-excerpt">{excerpt}</p>
    <footer class="article-meta">
      <time datetime={date} class="article-date">{date}</time>
      <span class="article-dot" aria-hidden="true">·</span>
      <span class="article-read">{readTime} leestijd</span>
      <span class="article-arrow" aria-hidden="true">→</span>
    </footer>
  </a>
</article>

<style>
.article-card {
  background: var(--color-bg-white);
  border: 0.5px solid var(--s2);
  border-radius: var(--r-md);
  overflow: hidden;
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
}
.article-card:hover {
  border-color: rgba(21,128,61,0.3);
  box-shadow: 0 4px 16px rgba(21,128,61,0.08);
  transform: translateY(-2px);
}
.article-urgent {
  border-left: 3px solid var(--g4);
  background: var(--g1);
}

.article-card-link {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 20px;
  height: 100%;
}

.article-card-header {
  display: flex;
  align-items: center;
  gap: 8px;
}
.article-tag {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--g4);
}
.article-urgent-badge {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #fff;
  background: var(--g4);
  border-radius: 3px;
  padding: 2px 6px;
}

.article-title {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 700;
  color: var(--s5);
  line-height: 1.25;
}
.article-excerpt {
  font-size: 13px;
  color: var(--s4);
  line-height: 1.6;
  flex: 1;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 4px;
}
.article-date, .article-read {
  font-size: 11.5px;
  color: var(--s3);
}
.article-dot { color: var(--s3); font-size: 10px; }
.article-arrow {
  margin-left: auto;
  font-size: 14px;
  color: var(--g4);
  font-weight: 600;
  transition: transform 0.15s;
}
.article-card:hover .article-arrow { transform: translateX(3px); }
</style>
