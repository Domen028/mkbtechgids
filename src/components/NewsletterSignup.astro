---
// NewsletterSignup.astro
---

<section class="newsletter" aria-labelledby="newsletter-heading">
  <div class="container newsletter-inner">

    <div class="newsletter-copy">
      <h2 id="newsletter-heading" class="newsletter-title">
        Blijf voorop. Zonder ruis.
      </h2>
      <p class="newsletter-sub">
        Tweewekelijkse briefing voor bestuurders en investeerders: wat er verandert in
        tech-regulering, welke tools het waard zijn en wat uw concurrenten al doen.
        Geen spam. Opzeggen wanneer u wilt.
      </p>
      <ul class="newsletter-promises" aria-label="Wat u ontvangt">
        <li><span class="promise-dot" aria-hidden="true">✓</span> NIS2 &amp; EU AI Act updates</li>
        <li><span class="promise-dot" aria-hidden="true">✓</span> Onafhankelijke tool-analyses</li>
        <li><span class="promise-dot" aria-hidden="true">✓</span> Leestijd: max. 4 minuten</li>
      </ul>
    </div>

    <form class="newsletter-form" action="/api/subscribe" method="POST" novalidate>
      <div class="form-group">
        <label for="nl-email" class="form-label">E-mailadres</label>
        <input
          id="nl-email"
          name="email"
          type="email"
          class="form-input"
          placeholder="u@bedrijf.nl"
          required
          autocomplete="email"
        />
      </div>
      <div class="form-group">
        <label for="nl-role" class="form-label">Uw rol <span class="form-optional">(optioneel)</span></label>
        <select id="nl-role" name="role" class="form-select">
          <option value="">Selecteer uw functie</option>
          <option value="ceo">CEO / Directeur</option>
          <option value="cfo">CFO / Financieel directeur</option>
          <option value="dga">DGA</option>
          <option value="investor">Investeerder / Aandeelhouder</option>
          <option value="board">Commissaris / RvB</option>
          <option value="other">Anders</option>
        </select>
      </div>
      <button type="submit" class="form-submit">
        Aanmelden voor de briefing <span aria-hidden="true">→</span>
      </button>
      <p class="form-social-proof"><i class="ti ti-users"></i> Meer dan 340 bestuurders gingen u voor.</p>
      <p class="form-privacy">
        Door u aan te melden gaat u akkoord met onze
        <a href="/privacy">privacyverklaring</a>.
      </p>
    </form>

  </div>
</section>

<style>
.newsletter {
  background: var(--n5);
  padding: 72px 0;
  position: relative;
  overflow: hidden;
}
.newsletter::before {
  content: '';
  position: absolute;
  left: -100px;
  top: -100px;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(21,128,61,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.newsletter-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
  position: relative;
  z-index: 1;
}

.newsletter-title {
  font-family: var(--font-display);
  font-size: clamp(24px, 3vw, 32px);
  font-weight: 700;
  color: var(--g1);
  letter-spacing: -0.02em;
  margin-bottom: 14px;
}
.newsletter-sub {
  font-size: 15px;
  line-height: 1.75;
  color: var(--s3);
  margin-bottom: 22px;
}
.newsletter-promises {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.newsletter-promises li {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--s3);
}
.promise-dot {
  color: var(--g4);
  font-weight: 700;
  font-size: 13px;
}

/* Form */
.newsletter-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: var(--r-lg);
  padding: 36px 32px;
}

.form-group { display: flex; flex-direction: column; gap: 10px; }
.form-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--s3);
  letter-spacing: 0.03em;
  text-transform: uppercase;
}
.form-optional { font-weight: 400; color: var(--s4); text-transform: none; }

.form-input,
.form-select {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: var(--r-sm);
  padding: 20px 18px;
  font-size: 15px;
  color: var(--g1);
  font-family: var(--font-body);
  transition: border-color 0.15s, background 0.15s;
  width: 100%;
  height: 56px;
  box-sizing: border-box;
}
.form-input::placeholder { color: var(--s4); }
.form-input:focus,
.form-select:focus {
  outline: none;
  border-color: var(--g4);
  background: rgba(21,128,61,0.06);
}
.form-select option { background: var(--n5); color: var(--g1); }

.form-submit {
  background: var(--g4);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  font-family: var(--font-body);
  padding: 16px 24px;
  border: none;
  border-radius: var(--r-sm);
  cursor: pointer;
  transition: background 0.15s, transform 0.15s;
  margin-top: 8px;
  letter-spacing: 0.01em;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.form-submit:hover { background: var(--g5); transform: translateY(-1px); }

.form-social-proof {
  font-size: 12px;
  color: var(--g4);
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: -4px;
}
.form-privacy {
  font-size: 11px;
  color: var(--s4);
  text-align: center;
  line-height: 1.5;
}
.form-privacy a { color: var(--s3); text-decoration: underline; }

@media (max-width: 768px) {
  .newsletter-inner { grid-template-columns: 1fr; gap: 36px; }
}
</style>
