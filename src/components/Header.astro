---
// src/components/Header.astro — FIXED
// Uses the real /public/logo.svg (DM Sans Bold, Illustrator export)
// Light nav surface so dark slate + forest green logo reads clearly
---

<!-- DM Sans Bold — required for logo.svg to render correctly -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@700&display=swap"
  rel="stylesheet"
/>

<header class="site-header">
  <div class="header-inner">

    <!-- Real logo from public/logo.svg -->
    <a href="/" class="nav-logo" aria-label="MKBTechGids — terug naar home">
      <img
        src="/logo.svg"
        alt="MKBTechGids"
        class="logo-img"
        width="48"
        height="51"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links" aria-label="Hoofdnavigatie">
      <a href="/nis2">NIS2</a>
      <a href="/ai-governance">AI Governance</a>
      <a href="/ai-tools">AI Tools</a>
      <a href="/crm">CRM</a>
      <a href="/artikelen">Artikelen</a>
    </nav>

    <!-- CTA -->
    <a href="/nis2" class="nav-cta" aria-label="Lees de NIS2 gids">
      NIS2 gids <span aria-hidden="true">→</span>
    </a>

    <!-- Mobile hamburger -->
    <button
      class="nav-toggle"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
      type="button"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="mobile-menu" aria-label="Mobiele navigatie" hidden>
    <a href="/nis2">NIS2</a>
    <a href="/ai-governance">AI Governance</a>
    <a href="/ai-tools">AI Tools</a>
    <a href="/crm">CRM</a>
    <a href="/artikelen">Artikelen</a>
    <a href="/nis2" class="mobile-cta">NIS2 gids lezen →</a>
  </nav>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 200;
  background: #f8fafc;
  border-bottom: 1px solid #e2e8f0;
  box-shadow: 0 1px 6px rgba(24,32,48,0.07);
}

.header-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 32px;
  height: 68px;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 28px;
}

.nav-logo {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}
.logo-img {
  display: block;
  height: 46px;
  width: auto;
}

.nav-links {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 28px;
  flex: 1;
  margin: 0;
  padding: 0;
}
.nav-links a {
  display: inline-block;
  font-size: 13.5px;
  font-weight: 500;
  color: #475569;
  white-space: nowrap;
  text-decoration: none;
  padding: 4px 0;
  border-bottom: 2px solid transparent;
  transition: color 0.14s, border-color 0.14s;
}
.nav-links a:hover,
.nav-links a[aria-current="page"] {
  color: #15803d;
  border-bottom-color: #15803d;
}

.nav-cta {
  flex-shrink: 0;
  white-space: nowrap;
  font-size: 13px;
  font-weight: 600;
  color: #fff;
  background: #15803d;
  border-radius: 6px;
  padding: 8px 18px;
  text-decoration: none;
  transition: background 0.14s, transform 0.14s;
}
.nav-cta:hover {
  background: #14532d;
  transform: translateY(-1px);
}

.nav-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  margin-left: auto;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: #475569;
  border-radius: 2px;
}

.mobile-menu {
  display: flex;
  flex-direction: column;
  background: #f8fafc;
  border-top: 1px solid #e2e8f0;
  padding: 8px 28px 20px;
}
.mobile-menu a {
  font-size: 15px;
  font-weight: 500;
  color: #475569;
  padding: 12px 0;
  border-bottom: 1px solid #e2e8f0;
  text-decoration: none;
  transition: color 0.14s;
}
.mobile-menu a:hover { color: #15803d; }
.mobile-menu a:last-child { border-bottom: none; }
.mobile-cta {
  display: inline-block;
  margin-top: 10px;
  background: #15803d;
  color: #fff !important;
  padding: 11px 20px !important;
  border-radius: 6px;
  border-bottom: none !important;
  font-size: 14px !important;
  font-weight: 600 !important;
  text-align: center;
}

@media (max-width: 900px) {
  .nav-links a { font-size: 12.5px; }
  .header-inner { gap: 20px; }
}
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-cta   { display: none; }
  .nav-toggle { display: flex; }
}
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu   = document.getElementById('mobile-menu') as HTMLElement;
  toggle?.addEventListener('click', () => {
    const isOpen = !menu.hidden;
    menu.hidden = isOpen;
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu.hidden) {
      menu.hidden = true;
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.focus();
    }
  });
</script>
