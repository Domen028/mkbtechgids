---
// src/components/Header.astro
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="nav-logo">
      <img src="/logo.svg" alt="MKBTechGids" width="120" height="46" />
    </a>
    <nav class="nav-links">
      <div class="nav-item">
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-label="NIS2 artikelen menu">NIS2</button>
        <div class="nav-dropdown">
          <a href="/nis2">NIS2 Overzicht</a>
          <a href="/nis2-compliance">NIS2 Compliance</a>
          <a href="/nis2-compliancy">NIS2 Implementatie</a>
        </div>
      </div>
      <a href="/">AI Governance</a>
      <a href="/">AI Tools</a>
      <a href="/">CRM</a>
      <div class="nav-item">
        <button class="nav-dropdown-trigger" aria-expanded="false" aria-label="Artikelen menu">Artikelen</button>
        <div class="nav-dropdown">
          <a href="/nis2">NIS2 Implementatie (beide artikelen)</a>
          <a href="/articles" class="nav-dropdown-all">Alle artikelen →</a>
        </div>
      </div>
    </nav>
    <a href="/nis2" class="nav-cta">NIS2 gids →</a>
    <button class="nav-toggle" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav id="mobile-menu" class="mobile-menu" hidden>
    <a href="/nis2">NIS2</a>
    <a href="/nis2-compliance">NIS2 Compliance</a>
    <a href="/nis2-compliancy">NIS2 Implementatie</a>
    <a href="/">AI Governance</a>
    <a href="/">AI Tools</a>
    <a href="/">CRM</a>
    <a href="/articles">Alle artikelen</a>
    <a href="/nis2" class="mobile-cta">NIS2 gids lezen →</a>
  </nav>
</header>

<style>
.site-header {
  position: sticky; top: 0; z-index: 200;
  background: var(--s1);
  border-bottom: 1px solid var(--s2);
  box-shadow: var(--shadow-sm);
}
.header-inner {
  display: flex; align-items: center; gap: 32px;
  height: var(--nav-height);
  max-width: var(--max-width);
  margin: 0 auto; padding: 0 28px;
}
.nav-logo { flex-shrink: 0; display: flex; align-items: center; }
.nav-logo img { height: 46px; width: auto; }
.nav-links { display: flex; gap: 28px; flex: 1; margin: 0; padding: 0; list-style: none; align-items: center; }
.nav-links a {
  font-size: 13.5px; font-weight: 500;
  color: var(--s4); text-decoration: none;
  padding: 4px 0; border-bottom: 2px solid transparent;
  transition: color 0.14s;
}
.nav-links a:hover { color: var(--g4); border-bottom-color: var(--g4); }

.nav-item { position: relative; display: flex; align-items: center; }
.nav-dropdown-trigger {
  background: none; border: none; font-family: inherit;
  font-size: 13.5px; font-weight: 500; color: var(--s4);
  padding: 4px 0; cursor: pointer; display: flex; align-items: center; gap: 6px;
  border-bottom: 2px solid transparent; transition: color 0.14s;
}
.nav-dropdown-trigger:hover { color: var(--g4); border-bottom-color: var(--g4); }
.nav-dropdown-trigger::after { content: '▼'; font-size: 8px; transition: transform 0.2s; }
.nav-dropdown-trigger[aria-expanded="true"]::after { transform: rotate(180deg); }
.nav-dropdown {
  position: absolute; top: calc(100% + 12px); left: -40px;
  background: white; border: 1px solid var(--s2); border-radius: var(--radius-md);
  min-width: 280px; padding: 8px 0;
  box-shadow: var(--shadow-lg); display: none; z-index: 1000;
}
.nav-dropdown.open { display: block; }
.nav-dropdown a {
  display: block; padding: 14px 20px; font-size: 14px; color: var(--s4);
  transition: all 0.14s; border-left: 3px solid transparent; text-decoration: none;
  border-bottom: none;
}
.nav-dropdown a:hover { background: var(--green-bg); color: var(--green); border-left-color: var(--green); }
.nav-dropdown-all {
  border-top: 1px solid var(--s2) !important;
  margin-top: 4px; padding-top: 12px !important;
  color: var(--green) !important; font-weight: 600 !important;
}

.nav-cta {
  font-size: 13px; font-weight: 600;
  color: var(--white); background: var(--g4);
  border-radius: var(--radius-md);
  padding: 8px 18px; text-decoration: none;
  transition: background 0.14s; border: none; cursor: pointer;
}
.nav-cta:hover { background: var(--g5); color: var(--white); }
.nav-toggle {
  display: none; flex-direction: column; justify-content: center;
  gap: 5px; background: none; border: none; cursor: pointer;
  padding: 6px; margin-left: auto;
}
.nav-toggle span { display: block; width: 22px; height: 2px; background: var(--s4); border-radius: 2px; }
.mobile-menu { display: none; }
.mobile-menu:not([hidden]) {
  display: flex; flex-direction: column;
  background: var(--s1); border-top: 1px solid var(--s2);
  padding: 8px 28px 20px;
}
.mobile-menu a {
  font-size: 15px; font-weight: 500; color: var(--s4);
  padding: 12px 0; border-bottom: 1px solid var(--s2);
  text-decoration: none;
}
.mobile-menu a:hover { color: var(--g4); }
.mobile-menu a:last-child { border-bottom: none; }
.mobile-cta {
  display: inline-block; margin-top: 10px;
  background: var(--g4); color: var(--white) !important;
  padding: 11px 20px !important; border-radius: var(--radius-md);
  border-bottom: none !important; font-size: 14px !important; font-weight: 600 !important;
}
@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .nav-toggle { display: flex; }
}
</style>

<script>
const toggle = document.querySelector('.nav-toggle');
const menu = document.getElementById('mobile-menu');
if (toggle && menu) {
  toggle.addEventListener('click', () => {
    const isOpen = !menu.hasAttribute('hidden');
    menu[isOpen ? 'setAttribute' : 'removeAttribute']('hidden', '');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
}

document.querySelectorAll('.nav-dropdown-trigger').forEach((trigger) => {
  const dropdown = trigger.nextElementSibling as HTMLElement | null;
  if (!dropdown) return;
  trigger.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    const isOpen = dropdown.classList.contains('open');
    document.querySelectorAll('.nav-dropdown.open').forEach(d => {
      d.classList.remove('open');
      (d.previousElementSibling as HTMLElement)?.setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      dropdown.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
    }
  });
});

document.addEventListener('click', () => {
  document.querySelectorAll('.nav-dropdown.open').forEach(d => {
    d.classList.remove('open');
    (d.previousElementSibling as HTMLElement)?.setAttribute('aria-expanded', 'false');
  });
});
</script>
