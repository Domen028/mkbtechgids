---
// Hero.astro — Executive-grade hero for CEO/CFO/DGA/investor audience
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="hero-inner container">

    <div class="hero-badge">
      <span class="hero-badge-dot" aria-hidden="true"></span>
      Onafhankelijk · Geen advertenties · Nederlands MKB
    </div>

    <h1 id="hero-heading" class="hero-heading">
      Technologie beslist mee.<br>
      <em>Of u het ziet of niet.</em>
    </h1>

    <p class="hero-sub">
      Voor bestuurders, CFO's en investeerders die willen begrijpen wat technologiekeuzes
      werkelijk betekenen voor <strong>bedrijfswaarde, operationeel risico en
      concurrentiepositie.</strong> Geen jargon. Geen verkooppraatjes. Wel het eerlijke beeld.
    </p>

    <div class="hero-stats" role="list" aria-label="Kerncijfers">
      <div class="stat" role="listitem">
        <span class="stat-val">14<span class="stat-accent">%</span></span>
        <span class="stat-label">Nederlandse organisaties<br>NIS2-compliant in 2026</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat" role="listitem">
        <span class="stat-val">€2,3<span class="stat-accent">M</span></span>
        <span class="stat-label">Gemiddelde boete bij<br>NIS2-overtreding</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat" role="listitem">
        <span class="stat-val">67<span class="stat-accent">%</span></span>
        <span class="stat-label">MKB kiest verkeerde<br>software (TNO, 2025)</span>
      </div>
    </div>

    <div class="hero-actions">
      <a href="/nis2" class="btn-primary">NIS2 gids lezen <span aria-hidden="true">→</span></a>
      <a href="/artikelen" class="btn-secondary">Alle onderwerpen</a>
    </div>

    <div class="hero-tagline" aria-label="Merktagline">
      <span class="tagline-line" aria-hidden="true"></span>
      <span>De route al verkend.</span>
      <span class="tagline-line" aria-hidden="true"></span>
    </div>

  </div>
</section>

<!-- Urgency strip -->
<div class="urgency-strip" role="alert" aria-live="polite">
  <div class="container urgency-inner">
    <div class="urgency-icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <p class="urgency-text">
      <strong>NIS2 Cyberbeveiligingswet — verwacht Q2 2026.</strong>
      Slechts 14% van Nederlandse organisaties is voorbereid.
      Wat betekent dit voor uw aansprakelijkheid als bestuurder?
    </p>
    <a href="/nis2" class="urgency-link">Lees de gids <span aria-hidden="true">→</span></a>
  </div>
</div>

<style>
/* ── Hero ────────────────────────────────────────────────── */
.hero {
  background: var(--n5);
  padding: 72px 0 64px;
  position: relative;
  overflow: hidden;
}

.hero-grid {
  position: absolute;
  inset: 0;
  opacity: 0.032;
  background-image:
    linear-gradient(rgba(21,128,61,0.9) 1px, transparent 1px),
    linear-gradient(90deg, rgba(21,128,61,0.9) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}

/* Soft glow bottom-right */
.hero::after {
  content: '';
  position: absolute;
  right: -80px;
  bottom: -80px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(21,128,61,0.12) 0%, transparent 70%);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 700px;
}

/* Badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(21,128,61,0.14);
  border: 1px solid rgba(21,128,61,0.30);
  border-radius: 100px;
  padding: 5px 14px;
  font-size: 11px;
  font-weight: 600;
  color: var(--g2);
  letter-spacing: 0.07em;
  text-transform: uppercase;
  margin-bottom: 24px;
  animation: fadeUp 0.5s ease both;
}
.hero-badge-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--g4);
  flex-shrink: 0;
}

/* Heading */
.hero-heading {
  font-family: var(--font-display);
  font-size: clamp(32px, 5vw, 46px);
  font-weight: 700;
  line-height: 1.15;
  color: var(--g1);
  letter-spacing: -0.02em;
  margin-bottom: 22px;
  animation: fadeUp 0.5s 0.08s ease both;
}
.hero-heading em {
  font-style: italic;
  color: var(--g2);
}

/* Subheading */
.hero-sub {
  font-size: 16px;
  line-height: 1.8;
  color: var(--s3);
  max-width: 560px;
  margin-bottom: 36px;
  animation: fadeUp 0.5s 0.15s ease both;
}
.hero-sub strong {
  color: var(--s2);
  font-weight: 500;
}

/* Stats */
.hero-stats {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 38px;
  flex-wrap: wrap;
  animation: fadeUp 0.5s 0.22s ease both;
}
.stat { padding: 0 28px 0 0; }
.stat:first-child { padding-left: 0; }
.stat-val {
  display: block;
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 700;
  color: var(--g1);
  letter-spacing: -0.02em;
  line-height: 1;
  margin-bottom: 4px;
}
.stat-accent { color: var(--g4); }
.stat-label {
  display: block;
  font-size: 12px;
  color: var(--s3);
  line-height: 1.45;
}
.stat-divider {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.08);
  margin-right: 28px;
  flex-shrink: 0;
}

/* Actions */
.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  align-items: center;
  animation: fadeUp 0.5s 0.28s ease both;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--g4);
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  padding: 12px 24px;
  border-radius: var(--r-sm);
  transition: background 0.15s, transform 0.15s;
  letter-spacing: 0.01em;
}
.btn-primary:hover {
  background: var(--g5);
  transform: translateY(-1px);
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  color: var(--s3);
  font-size: 14px;
  font-weight: 500;
  padding: 12px 24px;
  border-radius: var(--r-sm);
  border: 1px solid rgba(148,163,184,0.20);
  transition: color 0.15s, border-color 0.15s;
}
.btn-secondary:hover {
  color: var(--g1);
  border-color: rgba(148,163,184,0.40);
}

/* Tagline */
.hero-tagline {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-top: 40px;
  padding-top: 28px;
  border-top: 1px solid rgba(255,255,255,0.05);
  font-size: 11px;
  font-weight: 600;
  color: var(--s4);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  animation: fadeUp 0.5s 0.34s ease both;
}
.tagline-line {
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,0.04);
}

/* ── Urgency strip ───────────────────────────────────────── */
.urgency-strip {
  background: var(--n4);
  border-top: 1px solid rgba(30,58,110,0.6);
  border-bottom: 1px solid rgba(30,58,110,0.4);
}
.urgency-inner {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-top: 16px;
  padding-bottom: 16px;
}
.urgency-icon {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: var(--r-sm);
  background: rgba(251,191,36,0.10);
  border: 1px solid rgba(251,191,36,0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--a3);
}
.urgency-text {
  font-size: 13.5px;
  line-height: 1.55;
  color: var(--s3);
}
.urgency-text strong {
  color: var(--s2);
  font-weight: 600;
}
.urgency-link {
  margin-left: auto;
  flex-shrink: 0;
  font-size: 13px;
  font-weight: 600;
  color: var(--g2);
  white-space: nowrap;
  transition: color 0.15s;
}
.urgency-link:hover { color: var(--g1); }

/* ── Animations ──────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Responsive ──────────────────────────────────────────── */
@media (max-width: 640px) {
  .hero { padding: 52px 0 48px; }
  .hero-stats { gap: 24px; flex-direction: column; align-items: flex-start; }
  .stat { padding: 0; }
  .stat-divider { display: none; }
  .urgency-inner { flex-wrap: wrap; }
  .urgency-link { margin-left: 0; }
}
</style>
