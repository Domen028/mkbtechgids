---
// src/components/Hero.astro
// Executive hero for CEO / CFO / DGA / investor audience
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-glow"  aria-hidden="true"></div>

  <div class="container hero-inner">

    <span class="hero-badge">
      <span class="badge-dot" aria-hidden="true"></span>
      Onafhankelijk &middot; Geen advertenties &middot; Nederlands MKB
    </span>

    <h1 id="hero-heading" class="hero-heading">
      Technologie beslist mee.<br>
      <em>Of u het ziet of niet.</em>
    </h1>

    <p class="hero-sub">
      Voor bestuurders, CFO&rsquo;s en investeerders die willen begrijpen
      wat technologiekeuzes werkelijk betekenen voor
      <strong>bedrijfswaarde, operationeel risico en concurrentiepositie.</strong>
      Geen jargon. Geen verkooppraatjes. Wel het eerlijke beeld.
    </p>

    <div class="hero-stats" role="list" aria-label="Kerncijfers">
      <div class="stat" role="listitem">
        <span class="stat-val">14<span class="stat-unit">%</span></span>
        <span class="stat-label">Nederlandse organisaties<br>NIS2-compliant in 2026</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat" role="listitem">
        <span class="stat-val">&euro;2,3<span class="stat-unit">M</span></span>
        <span class="stat-label">Gemiddelde boete bij<br>NIS2-overtreding</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat" role="listitem">
        <span class="stat-val">67<span class="stat-unit">%</span></span>
        <span class="stat-label">MKB kiest verkeerde<br>software (TNO, 2025)</span>
      </div>
    </div>

    <div class="hero-actions">
      <a href="/nis2" class="btn-primary">
        NIS2 gids lezen <span aria-hidden="true">→</span>
      </a>
      <a href="/artikelen" class="btn-secondary">Alle onderwerpen</a>
    </div>

    <div class="hero-tagline" aria-label="De route al verkend">
      <span class="tagline-line" aria-hidden="true"></span>
      <span>De route al verkend.</span>
      <span class="tagline-line" aria-hidden="true"></span>
    </div>

  </div>
</section>


<style>
.hero {
  background: var(--bg-dark);
  padding: 76px 0 68px;
  position: relative; overflow: hidden;
}
.hero-grid {
  position: absolute; inset: 0; opacity: 0.033; pointer-events: none;
  background-image:
    linear-gradient(rgba(21,128,61,0.9) 1px, transparent 1px),
    linear-gradient(90deg, rgba(21,128,61,0.9) 1px, transparent 1px);
  background-size: 48px 48px;
}
.hero-glow {
  position: absolute; right: -120px; bottom: -120px;
  width: 480px; height: 480px; pointer-events: none;
  background: radial-gradient(circle, rgba(21,128,61,0.13) 0%, transparent 68%);
}
.hero-inner { position: relative; z-index: 1; max-width: 700px; }

.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(21,128,61,0.14);
  border: 1px solid rgba(21,128,61,0.30);
  border-radius: 100px; padding: 5px 14px;
  font-size: 11px; font-weight: 600; color: var(--g2);
  letter-spacing: 0.07em; text-transform: uppercase;
  margin-bottom: 26px;
  animation: fadeUp 0.55s ease both;
}
.badge-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--g4); flex-shrink: 0;
  animation: pulseDot 2.5s ease-in-out infinite;
}

.hero-heading {
  font-family: var(--font-display);
  font-size: clamp(30px, 5vw, 48px);
  font-weight: 700; line-height: 1.14;
  color: var(--g1); letter-spacing: -0.025em;
  margin-bottom: 22px;
  animation: fadeUp 0.55s 0.08s ease both;
}
.hero-heading em { font-style: italic; color: var(--g2); }

.hero-sub {
  font-size: 16px; line-height: 1.8; color: var(--s3);
  max-width: 560px; margin-bottom: 38px;
  animation: fadeUp 0.55s 0.15s ease both;
}
.hero-sub strong { color: var(--s2); font-weight: 500; }

.hero-stats {
  display: flex; align-items: center; flex-wrap: wrap;
  margin-bottom: 40px;
  animation: fadeUp 0.55s 0.22s ease both;
}
.stat { padding: 0 32px 0 0; }
.stat:first-child { padding-left: 0; }
.stat-val {
  display: block; font-family: var(--font-display);
  font-size: 28px; font-weight: 700; color: var(--g1);
  letter-spacing: -0.02em; line-height: 1; margin-bottom: 5px;
}
.stat-unit { color: var(--g4); }
.stat-label { display: block; font-size: 12px; color: var(--s3); line-height: 1.45; }
.stat-divider {
  width: 1px; height: 38px;
  background: rgba(255,255,255,0.08);
  margin-right: 32px; flex-shrink: 0;
}

.hero-actions {
  display: flex; gap: 14px; flex-wrap: wrap; align-items: center;
  animation: fadeUp 0.55s 0.28s ease both;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--g4); color: #fff;
  font-size: 14px; font-weight: 600;
  padding: 13px 26px; border-radius: var(--r-sm);
  letter-spacing: 0.01em; text-decoration: none;
  transition: background 0.14s, transform 0.14s;
}
.btn-primary:hover { background: var(--g5); transform: translateY(-1px); }
.btn-secondary {
  display: inline-flex; align-items: center; gap: 6px;
  background: transparent; color: var(--s3);
  font-size: 14px; font-weight: 500;
  padding: 13px 26px; border-radius: var(--r-sm);
  border: 1px solid rgba(148,163,184,0.22); text-decoration: none;
  transition: color 0.14s, border-color 0.14s;
}
.btn-secondary:hover { color: var(--g1); border-color: rgba(148,163,184,0.45); }

.hero-tagline {
  display: flex; align-items: center; gap: 14px;
  margin-top: 44px; padding-top: 28px;
  border-top: 1px solid rgba(255,255,255,0.05);
  font-size: 11px; font-weight: 600; color: var(--s4);
  letter-spacing: 0.1em; text-transform: uppercase;
  animation: fadeUp 0.55s 0.34s ease both;
}
.tagline-line { flex: 1; height: 1px; background: rgba(255,255,255,0.05); }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes pulseDot {
  0%, 100% { opacity: 1; } 50% { opacity: 0.35; }
}

@media (max-width: 640px) {
  .hero { padding: 52px 0 48px; }
  .hero-stats { flex-direction: column; align-items: flex-start; gap: 20px; }
  .stat { padding: 0; }
  .stat-divider { display: none; }
  .urgency-inner { flex-wrap: wrap; gap: 10px; }
  .urgency-link { margin-left: 0; }
}
</style>
