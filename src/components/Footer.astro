---
// src/components/Footer.astro
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col footer-brand">
      <a href="/" class="footer-logo">
        <img src="/logo.svg" alt="MKBTechGids" width="120" height="46" />
      </a>
      <p class="footer-tagline">Technologie met vertrouwen.</p>
      <p class="footer-desc">Onafhankelijke technologiegids voor het Nederlandse MKB.</p>
    </div>

    <div class="footer-col">
      <h4 class="footer-head">Onderwerpen</h4>
      <nav class="footer-nav">
        <a href="/nis2">NIS2 Compliance</a>
        <a href="/">AI Governance</a>
        <a href="/">AI Tools</a>
        <a href="/">CRM Software</a>
      </nav>
    </div>

    <div class="footer-col">
      <h4 class="footer-head">Bedrijf</h4>
      <nav class="footer-nav">
        <a href="/">Over ons</a>
        <a href="/">Contact</a>
        <a href="/">Privacy</a>
      </nav>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; 2026 MKBTechGids. Alle rechten voorbehouden.</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--s5);
  color: var(--s3);
  padding: 48px 28px 24px;
  margin-top: 80px;
  border-top: 1px solid var(--s4);
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 32px;
}

.footer-brand {
  max-width: 320px;
}

.footer-logo {
  display: inline-block;
  margin-bottom: 12px;
}

.footer-logo img {
  height: 46px;
  width: auto;
  filter: brightness(0) invert(1);
}

.footer-tagline {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--s3);
  margin-bottom: 12px;
  margin-top: 8px;
}

.footer-desc {
  font-size: 13px;
  line-height: 1.6;
  color: var(--s3);
}

.footer-col {
  display: flex;
  flex-direction: column;
}

.footer-head {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 16px;
  letter-spacing: 0.5px;
}

.footer-nav {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.footer-nav a {
  font-size: 13px;
  color: var(--s3);
  text-decoration: none;
  transition: color 0.14s;
}

.footer-nav a:hover {
  color: var(--g2);
}

.footer-bottom {
  border-top: 1px solid var(--s4);
  padding-top: 24px;
  text-align: center;
}

.footer-bottom p {
  font-size: 12px;
  color: var(--s3);
}

@media (max-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 32px;
  }
}
</style>
